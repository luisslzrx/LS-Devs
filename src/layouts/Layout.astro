---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	image?: string;
	url?: string;
	author?: string;
	type?: string;
	siteName?: string;
	locale?: string;
	card?: string;
}

const {
	title = "Páginas web para negocios en México | geradev",
	description = "Diseño y desarrollo de páginas web profesionales para negocios locales en México. Precios accesibles, entrega rápida y soporte incluido. Solicita cotización gratis.",
	keywords = "desarrollo de páginas web en CDMX, diseñador web freelance México, diseño web para negocios, desarrollo web profesional México, creación de páginas web",
	image = "/geradev.png",
	url = "https://geradev.com.mx/",
	author = "Luis Salazar",
	type = "website",
	siteName = "geradev | Desarrollo Web Profesional México",
	locale = "es_MX",
	card = "summary_large_image",
} = Astro.props;
---

<!doctype html>
<html lang="es-MX" class="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>
		<link rel="icon" type="image/png" href="/favicon-luis.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google Analytics -->
		<script
			async
			src="https://www.googletagmanager.com/gtag/js?id=G-8Q25R0FC4M"
		></script>
		<script>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());

			gtag("config", "G-8Q25R0FC4M");
		</script>

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content={author} />
		<meta name="robots" content="index, follow" />
		<meta name="language" content="Spanish" />
		<meta name="geo.region" content="MX-VER" />
		<meta
			name="geo.placename"
			content="Ciudad de México, Xalapa, Veracruz"
		/>
		<meta name="geo.position" content="19.4326;-99.1332" />
		<meta name="ICBM" content="19.4326,-99.1332" />

		<!-- Open Graph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:url" content={url} />
		<meta property="og:type" content={type} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content={locale} />
		<meta
			property="og:image:alt"
			content="Desarrollo de páginas web profesionales en México"
		/>
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter Card Meta Tags -->
		<meta name="twitter:card" content={card} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
		<meta name="twitter:creator" content={author} />
		<meta
			name="twitter:image:alt"
			content="Desarrollo web profesional en Ciudad de México"
		/>

		<!-- Canonical URL -->
		<link rel="canonical" href={url} />

		<!-- Additional SEO Meta Tags -->
		<meta name="theme-color" content="#2d85f0" />
		<meta name="msapplication-TileColor" content="#2d85f0" />
		<meta name="application-name" content="geradev - Desarrollo Web" />
		<meta name="apple-mobile-web-app-title" content="geradev" />
		<meta name="format-detection" content="telephone=no" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />

		<!-- Structured Data (JSON-LD) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "ProfessionalService",
				"name": "geradev - Desarrollo Web Profesional",
				"description": "Desarrollo de páginas web profesionales en Ciudad de México. Landing pages, tiendas online y diseño web para negocios.",
				"url": "https://geradev.com.mx/",
				"image": "/luisdev-logo.png",
				"telephone": "+52 1 55 1234 5678",
				"priceRange": "$5000 - $50000",
				"address": {
					"@type": "PostalAddress",
					"addressLocality": "Ciudad de México",
					"addressRegion": "CMX",
					"addressCountry": "MX",
					"postalCode": "06000"
				},
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": 19.4326,
					"longitude": -99.1332
				},
				"openingHours": "Mo-Fr 09:00-18:00",
				"sameAs": [
					"https://github.com/luisslzrx",
					"https://www.linkedin.com/in/luis-gerardo-salazar-aguilar/"
				],
				"serviceType": [
					"Desarrollo de Páginas Web",
					"Diseño Web Profesional",
					"Creación de Landing Pages",
					"Desarrollo de Tiendas Online",
					"Mantenimiento Web",
					"SEO Técnico"
				],
				"areaServed": [
					{
						"@type": "City",
						"name": "Ciudad de México",
						"@id": "https://en.wikipedia.org/wiki/Mexico_City"
					},
					{
						"@type": "City",
						"name": "Xalapa",
						"@id": "https://en.wikipedia.org/wiki/Xalapa"
					},
					{
						"@type": "State",
						"name": "Veracruz",
						"@id": "https://en.wikipedia.org/wiki/Veracruz"
					}
				],
				"knowsAbout": [
					"HTML",
					"CSS",
					"JavaScript",
					"Astro",
					"Tailwind CSS",
					"Python Django",
					"PHP",
					"WordPress",
					"UX/UI",
					"SEO técnico",
					"Diseño de landing pages",
					"Desarrollo de ecommerce",
					"Desarrollo web responsive"
				],
				"offers": {
					"@type": "Offer",
					"itemOffered": "Servicio de desarrollo web",
					"priceCurrency": "MXN",
					"price": "5000",
					"availability": "https://schema.org/InStock",
					"seller": {
						"@type": "Person",
						"name": "Luis Salazar"
					}
				}
			}
		</script>
	</head>

	<body>
		<Header />
		<slot />
		<Footer />

		<!-- WhatsApp Float Button -->
		<button id="whatsappButton" class="whatsapp-float">
			<svg viewBox="0 0 24 24" fill="currentColor" class="whatsapp-icon">
				<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
			</svg>
		</button>

		<!-- WhatsApp Chat Popup -->
		<div id="whatsappChat" class="whatsapp-chat hidden">
			<div class="chat-header">
				<div class="chat-header-content">
					<svg viewBox="0 0 24 24" fill="currentColor" class="chat-header-icon">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
					</svg>
					<div>
						<p class="chat-header-title">WhatsApp</p>
						<p class="chat-header-subtitle">Responde en minutos</p>
					</div>
				</div>
				<button id="closeChat" class="close-chat">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M18 6L6 18M6 6l12 12"/>
					</svg>
				</button>
			</div>
			<div class="chat-body">
				<p class="chat-message">¡Hola! ¿En qué puedo ayudarte hoy?</p>
			</div>
			<div class="chat-footer">
				<textarea id="whatsappMessage" placeholder="Escribe tu mensaje..." rows="3">Hola, quiero información</textarea>
				<button id="sendWhatsApp" class="send-button">
					<svg viewBox="0 0 24 24" fill="currentColor">
						<path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
					</svg>
				</button>
			</div>
		</div>

		<style>
			.whatsapp-float {
				position: fixed;
				bottom: 24px;
				right: 24px;
				width: 60px;
				height: 60px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				z-index: 1000;
				/* Liquid Glass Effect - transparent without shadows */
				background: rgba(255, 255, 255, 0.15);
				backdrop-filter: blur(20px);
				-webkit-backdrop-filter: blur(20px);
				border: 1px solid rgba(255, 255, 255, 0.3);
				cursor: pointer;
				transition: all 0.3s ease;
			}

			.whatsapp-float:hover {
				background: rgba(255, 255, 255, 0.25);
				transform: scale(1.1);
			}

			.whatsapp-icon {
				width: 32px;
				height: 32px;
				color: white;
			}

			.whatsapp-chat {
				position: fixed;
				bottom: 100px;
				right: 24px;
				width: 320px;
				max-width: calc(100vw - 48px);
				border-radius: 16px;
				z-index: 999;
				display: flex;
				flex-direction: column;
				overflow: hidden;
				transition: all 0.3s ease;
				/* Liquid Glass Effect for chat */
				background: rgba(255, 255, 255, 0.1);
				backdrop-filter: blur(20px);
				-webkit-backdrop-filter: blur(20px);
				border: 1px solid rgba(255, 255, 255, 0.2);
			}

			.whatsapp-chat.hidden {
				display: none;
			}

			.chat-header {
				background: rgba(37, 211, 102, 0.2);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				padding: 16px;
				display: flex;
				align-items: center;
				justify-content: space-between;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
			}

			.chat-header-content {
				display: flex;
				align-items: center;
				gap: 12px;
			}

			.chat-header-icon {
				width: 40px;
				height: 40px;
				color: white;
			}

			.chat-header-title {
				color: white;
				font-weight: 600;
				font-size: 16px;
				margin: 0;
			}

			.chat-header-subtitle {
				color: rgba(255, 255, 255, 0.9);
				font-size: 12px;
				margin: 2px 0 0 0;
			}

			.close-chat {
				background: none;
				border: none;
				color: white;
				cursor: pointer;
				padding: 4px;
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.close-chat svg {
				width: 20px;
				height: 20px;
			}

			.chat-body {
				padding: 16px;
				background: rgba(255, 255, 255, 0.05);
			}

			.chat-message {
				background: rgba(255, 255, 255, 0.15);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				padding: 12px;
				border-radius: 12px;
				margin: 0;
				font-size: 14px;
				color: white;
				border: 1px solid rgba(255, 255, 255, 0.1);
			}

			.chat-footer {
				padding: 12px;
				background: rgba(255, 255, 255, 0.05);
				display: flex;
				gap: 8px;
				align-items: flex-end;
				border-top: 1px solid rgba(255, 255, 255, 0.1);
			}

			#whatsappMessage {
				flex: 1;
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 12px;
				padding: 10px 12px;
				font-size: 14px;
				resize: none;
				outline: none;
				font-family: inherit;
				background: rgba(255, 255, 255, 0.1);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				color: white;
			}

			#whatsappMessage::placeholder {
				color: rgba(255, 255, 255, 0.5);
			}

			#whatsappMessage:focus {
				border-color: rgba(37, 211, 102, 0.5);
				background: rgba(255, 255, 255, 0.15);
			}

			.send-button {
				background: rgba(37, 211, 102, 0.3);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				border: 1px solid rgba(37, 211, 102, 0.4);
				border-radius: 50%;
				width: 40px;
				height: 40px;
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
				transition: all 0.3s ease;
				flex-shrink: 0;
			}

			.send-button:hover {
				background: rgba(37, 211, 102, 0.5);
				border-color: rgba(37, 211, 102, 0.6);
			}

			.send-button svg {
				width: 20px;
				height: 20px;
				color: white;
			}

			@media (max-width: 640px) {
				.whatsapp-float {
					bottom: 20px;
					right: 20px;
					width: 52px;
					height: 52px;
				}

				.whatsapp-icon {
					width: 28px;
					height: 28px;
				}

				.whatsapp-chat {
					bottom: 85px;
					right: 20px;
					width: calc(100vw - 40px);
				}
			}
		</style>

		<script>
			const whatsappButton = document.getElementById('whatsappButton');
			const whatsappChat = document.getElementById('whatsappChat');
			const closeChat = document.getElementById('closeChat');
			const sendWhatsApp = document.getElementById('sendWhatsApp');
			const whatsappMessage = document.getElementById('whatsappMessage');

			let isOpen = false;

			whatsappButton.addEventListener('click', () => {
				isOpen = !isOpen;
				if (isOpen) {
					whatsappChat.classList.remove('hidden');
				} else {
					whatsappChat.classList.add('hidden');
				}
			});

			closeChat.addEventListener('click', () => {
				isOpen = false;
				whatsappChat.classList.add('hidden');
			});

			sendWhatsApp.addEventListener('click', () => {
				const message = whatsappMessage.value.trim();
				if (message) {
					const encodedMessage = encodeURIComponent(message);
					const whatsappUrl = `https://wa.me/525632193996?text=${encodedMessage}`;
					window.open(whatsappUrl, '_blank');
					whatsappMessage.value = '';
					isOpen = false;
					whatsappChat.classList.add('hidden');
				}
			});

			whatsappMessage.addEventListener('keypress', (e) => {
				if (e.key === 'Enter' && !e.shiftKey) {
					e.preventDefault();
					sendWhatsApp.click();
				}
			});
		</script>

		<script>
			// Global Apple-like reveal animation using IntersectionObserver
			(function () {
				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('revealed');
							observer.unobserve(entry.target);
						}
					});
				}, {
					root: null,
					threshold: 0.05,
					rootMargin: '0px 0px -50px 0px'
				});

				function initReveals() {
					const elements = document.querySelectorAll('.apple-reveal');
					elements.forEach((el) => observer.observe(el));
				}

				// Run immediately
				initReveals();

				// Re-run if page content changes (e.g. navigation)
				document.addEventListener('astro:page-load', initReveals);
			})();
		</script>
	</body>
</html>
