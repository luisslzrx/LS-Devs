---
import LayoutInterna from "../layouts/LayoutInterna.astro";
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";

const posts = await getCollection("blog");

posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<LayoutInterna
  title="Blog de Desarrollo Web | geradev"
  description="Artículos sobre desarrollo de páginas web, landing pages y tiendas online en México. Estrategias para negocios que buscan atraer clientes y crecer en internet."
  url="https://geradev.com.mx/blog"
>

<main class="w-full min-h-screen bg-gradient-to-b from-gray-900 to-black pt-32 pb-24">

<section class="w-full max-w-[1200px] mx-auto px-6 md:px-8">

  <!-- Banner -->
  <div class="relative w-full min-h-[300px] flex items-center mb-16">
    <div class="max-w-2xl">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight tracking-tight drop-shadow-lg">
        Mi blog
      </h1>
      <p class="mt-6 text-lg md:text-xl text-white/85 leading-relaxed font-light">
        Artículos sobre desarrollo web, Astro, JavaScript, SEO técnico y experiencias construyendo proyectos web
      </p>
    </div>
  </div>

  <!-- GRID DE POSTS -->
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

    {posts.map(post => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        image={post.data.image}
        url={`/blog/${post.slug}`}
        date={post.data.date}
      />
    ))}

  </div>

</section>

</main>

</Layout>