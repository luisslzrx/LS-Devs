---
import LayoutInterna from "../layouts/LayoutInterna.astro";
import { getCollection } from "astro:content";
import ProyectosCard from "../components/ProyectosCard.astro";

const proyectos = await getCollection("proyectos");

proyectos.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<LayoutInterna
title="geradev | Sitios web profesionales para tu negocio"
description="Proyectos de desarrollo web, aplicaciones y soluciones construidas con diferentes tecnologías."
url="https://geradev.com.mx/proyectos"
>

<main class="w-full min-h-screen bg-gradient-to-b from-gray-900 to-black pt-32 pb-24">

<section class="w-full max-w-[1200px] mx-auto px-6 md:px-8">

  <!-- Banner -->
  <div class="relative w-full min-h-[300px] flex items-center mb-16">
    <div class="max-w-2xl">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight tracking-tight drop-shadow-lg">
        Mis proyectos
      </h1>
      <p class="mt-6 text-lg md:text-xl text-white/85 leading-relaxed font-light">
        Proyectos de desarrollo web, aplicaciones y soluciones construidas con diferentes tecnologías
      </p>
    </div>
  </div>

  <!-- GRID -->
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

    {proyectos.map(proyecto => (
      <ProyectosCard
        title={proyecto.data.title}
        description={proyecto.data.description}
        image={proyecto.data.image}
        url={proyecto.data.link}
        date={proyecto.data.date}
        tags={proyecto.data.tags}
  />
    ))}

  </div>

</section>

</main>

</LayoutInterna>