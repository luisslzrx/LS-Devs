---
// Diferenciadores - 11 razones para elegir Geradev
---

<section class="px-6 py-24 md:px-12 lg:pl-20 lg:pr-0">
  <div class="flex flex-col md:flex-row items-start gap-10">

    <!-- ══ LEFT: sticky card con imagen ══ -->
    <div class="hidden md:block flex-none w-full md:w-1/2 relative md:sticky md:top-12 self-start">
      <div
        class="relative rounded-[24px] overflow-hidden flex flex-col h-[80vh] min-h-[300px]"
        style="
          background: rgba(255,255,255,0.05);
          backdrop-filter: blur(20px);
          -webkit-backdrop-filter: blur(20px);
          border: 1px solid rgba(255,255,255,0.1);
          box-shadow: 0 8px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.08);
        "
      >
        <!-- preview image -->
        <div class="relative z-10 flex-1 m-6 mt-6 mb-0 rounded-[14px] overflow-hidden"
          style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);">
          <img
            id="diff-img"
            src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&q=80"
            alt="Diferenciador preview"
            class="w-full h-full object-cover block transition-opacity duration-[350ms] ease-in-out"
          />
          <!-- Overlay con título del item activo -->
          <div class="absolute inset-0 flex items-end pointer-events-none"
            style="background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 45%);">
            <p id="diff-img-title"
              class="text-white text-2xl font-bold p-6 transition-opacity duration-300 ease-in-out">
              SEO Optimizado
            </p>
          </div>
        </div>

        <!-- author -->
        <div class="relative z-10 flex items-center gap-3 px-6 pb-[22px] pt-[18px]">
          <div class="w-[42px] h-[42px] rounded-[10px] flex items-center justify-center flex-shrink-0"
            style="background: rgba(80,193,252,0.12); border: 1px solid rgba(80,193,252,0.2);">
            <span class="text-[#50C1FC] font-bold text-lg">G</span>
          </div>
          <div>
            <span class="block text-[11px] font-normal text-white/40">Desarrollado por</span>
            <strong class="block text-[17px] font-bold text-white tracking-[-0.01em]">Geradev</strong>
          </div>
        </div>
      </div>
    </div>

    <!-- ══ RIGHT: scrollable list ══ -->
    <div class="w-full md:w-1/2 pt-7 md:pt-0">
      <!-- Título -->
      <div class="mb-12">
        <h2 class="text-4xl md:text-6xl lg:text-7xl font-bold leading-[0.9] tracking-tight text-white mb-6">
          La diferencia está<br class="hidden md:block" /> en los detalles.
        </h2>
        <p class="text-base md:text-lg text-white/50 leading-relaxed">
          Cada sitio web está diseñado para ofrecer una mejor experiencia, mayor rendimiento y las herramientas necesarias para ayudar a que tu negocio crezca.
        </p>
      </div>

      <p class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-6">11 diferenciadores</p>

      <ul class="list-none m-0 p-0">

        <li class="diff-item active flex flex-col justify-between py-[22px] border-b cursor-pointer pt-0" data-index="0" data-title="SEO Optimizado">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white text-[30px] font-medium tracking-[-0.02em]">SEO Optimizado</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease text-white/65" style="max-height: 80px;">Mejor visibilidad en buscadores</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&q=80" alt="SEO Optimizado" class="w-full h-48 object-cover" />
          </div>
        </li>

        <li class="diff-item flex flex-col justify-between py-[22px] border-b cursor-pointer" data-index="1" data-title="Alto Rendimiento">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white/30 text-[26px] font-normal">Alto Rendimiento</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease max-h-0 overflow-hidden text-transparent">Sitios rápidos y eficientes</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=80" alt="Alto Rendimiento" class="w-full h-48 object-cover" />
          </div>
        </li>

        <li class="diff-item flex flex-col justify-between py-[22px] border-b cursor-pointer" data-index="2" data-title="Diseño Responsive">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white/30 text-[26px] font-normal">Diseño Responsive</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease max-h-0 overflow-hidden text-transparent">Perfecto en cualquier dispositivo</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1555421689-491a97ff2040?w=600&q=80" alt="Diseño Responsive" class="w-full h-48 object-cover" />
          </div>
        </li>

        <li class="diff-item flex flex-col justify-between py-[22px] border-b cursor-pointer" data-index="3" data-title="Carga Ultrarrápida">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white/30 text-[26px] font-normal">Carga Ultrarrápida</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease max-h-0 overflow-hidden text-transparent">Tiempos de carga mínimos</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600&q=80" alt="Carga Ultrarrápida" class="w-full h-48 object-cover" />
          </div>
        </li>

        <li class="diff-item flex flex-col justify-between py-[22px] border-b cursor-pointer" data-index="4" data-title="Seguridad Avanzada">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white/30 text-[26px] font-normal">Seguridad Avanzada</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease max-h-0 overflow-hidden text-transparent">Protección de datos garantizada</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1563986768609-322da13575f3?w=600&q=80" alt="Seguridad Avanzada" class="w-full h-48 object-cover" />
          </div>
        </li>

        <li class="diff-item flex flex-col justify-between py-[22px] border-b cursor-pointer" data-index="5" data-title="Código Escalable">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white/30 text-[26px] font-normal">Código Escalable</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease max-h-0 overflow-hidden text-transparent">Crecimiento sin límites</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=600&q=80" alt="Código Escalable" class="w-full h-48 object-cover" />
          </div>
        </li>

        <li class="diff-item flex flex-col justify-between py-[22px] border-b cursor-pointer" data-index="6" data-title="Experiencia de Usuario">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white/30 text-[26px] font-normal">Experiencia de Usuario</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease max-h-0 overflow-hidden text-transparent">UX intuitiva y atractiva</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1551434678-e076c223a692?w=600&q=80" alt="Experiencia de Usuario" class="w-full h-48 object-cover" />
          </div>
        </li>

        <li class="diff-item flex flex-col justify-between py-[22px] border-b cursor-pointer" data-index="7" data-title="Diseño Personalizado">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white/30 text-[26px] font-normal">Diseño Personalizado</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease max-h-0 overflow-hidden text-transparent">Único para tu marca</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1561070791-2526d30994b5?w=600&q=80" alt="Diseño Personalizado" class="w-full h-48 object-cover" />
          </div>
        </li>

        <li class="diff-item flex flex-col justify-between py-[22px] border-b cursor-pointer" data-index="8" data-title="Integración de Herramientas">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white/30 text-[26px] font-normal">Integración de Herramientas</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease max-h-0 overflow-hidden text-transparent">Conectado con tu ecosistema</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=600&q=80" alt="Integración de Herramientas" class="w-full h-48 object-cover" />
          </div>
        </li>

        <li class="diff-item flex flex-col justify-between py-[22px] border-b cursor-pointer" data-index="9" data-title="Mantenimiento Continuo">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white/30 text-[26px] font-normal">Mantenimiento Continuo</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease max-h-0 overflow-hidden text-transparent">Actualizaciones y soporte constante</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=600&q=80" alt="Mantenimiento Continuo" class="w-full h-48 object-cover" />
          </div>
        </li>

        <li class="diff-item flex flex-col justify-between py-[22px] border-b cursor-pointer" data-index="10" data-title="Soporte Profesional">
          <div class="flex-1">
            <h4 class="diff-item-title m-0 mb-1 leading-[1.15] transition-all duration-300 ease text-white/30 text-[26px] font-normal">Soporte Profesional</h4>
            <p class="diff-item-desc m-0 text-[13px] leading-[1.5] transition-all duration-[350ms] ease max-h-0 overflow-hidden text-transparent">Asistencia experta cuando la necesites</p>
          </div>
          <div class="diff-mobile-img-container md:hidden w-full overflow-hidden rounded-2xl">
            <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600&q=80" alt="Soporte Profesional" class="w-full h-48 object-cover" />
          </div>
        </li>

      </ul>

      <!-- CTA -->
      <div class="pt-10 pb-4">
        <a href="#contacto" class="inline-flex items-center px-[26px] py-[13px] rounded-full border text-white text-[14px] font-medium whitespace-nowrap transition-all duration-200 ease bg-white/5 hover:bg-white/10 hover:border-white/45 hover:scale-105 active:scale-95" style="border-color: rgba(255,255,255,0.22);">
          Cotizar proyecto
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .diff-item {
    border-bottom-color: rgba(255,255,255,0.06);
  }
  .diff-item:hover .diff-item-title {
    color: rgba(255,255,255,0.55);
  }
  .diff-mobile-img-container {
    max-height: 0px;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), margin-top 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .diff-item.active .diff-mobile-img-container {
    max-height: 250px;
    opacity: 1;
    margin-top: 12px;
  }
  @media (max-width: 767px) {
    .diff-item-title {
      font-size: 22px;
    }
    .diff-item-desc {
      font-size: 13px;
    }
  }
</style>

<script is:inline>
(function () {
  const TITLES = [
    'SEO Optimizado',
    'Alto Rendimiento',
    'Diseño Responsive',
    'Carga Ultrarrápida',
    'Seguridad Avanzada',
    'Código Escalable',
    'Experiencia de Usuario',
    'Diseño Personalizado',
    'Integración de Herramientas',
    'Mantenimiento Continuo',
    'Soporte Profesional'
  ];

  const IMAGES = [
    'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&q=80',
    'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=80',
    'https://images.unsplash.com/photo-1555421689-491a97ff2040?w=600&q=80',
    'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600&q=80',
    'https://images.unsplash.com/photo-1563986768609-322da13575f3?w=600&q=80',
    'https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=600&q=80',
    'https://images.unsplash.com/photo-1551434678-e076c223a692?w=600&q=80',
    'https://images.unsplash.com/photo-1561070791-2526d30994b5?w=600&q=80',
    'https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=600&q=80',
    'https://images.unsplash.com/photo-1553877522-43269d4ea984?w=600&q=80',
    'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600&q=80'
  ];

  const items    = Array.from(document.querySelectorAll('.diff-item'));
  const img      = document.getElementById('diff-img');
  const imgTitle = document.getElementById('diff-img-title');
  let current    = 0;

  function activate(idx) {
    if (idx === current) {
      // Aun así nos aseguramos de que el activo tenga las clases correctas
    }
    current = idx;

    items.forEach(function (el) {
      const i      = parseInt(el.dataset.index, 10);
      const title  = el.querySelector('.diff-item-title');
      const desc   = el.querySelector('.diff-item-desc');

      if (i === idx) {
        el.classList.add('active');
        title.classList.remove('text-white/30', 'text-[26px]', 'font-normal');
        title.classList.add('text-white', 'text-[30px]', 'font-medium');
        desc.classList.remove('max-h-0', 'overflow-hidden', 'text-transparent');
        desc.classList.add('text-white/65');
        desc.style.maxHeight = '80px';
      } else {
        el.classList.remove('active');
        title.classList.add('text-white/30', 'text-[26px]', 'font-normal');
        title.classList.remove('text-white', 'text-[30px]', 'font-medium');
        desc.classList.add('max-h-0', 'overflow-hidden', 'text-transparent');
        desc.classList.remove('text-white/65');
        desc.style.maxHeight = '0px';
      }
    });

    // Imagen + título overlay con fade
    img.style.opacity = '0';
    imgTitle.style.opacity = '0';
    setTimeout(function () {
      img.src = IMAGES[idx] || IMAGES[0];
      imgTitle.textContent = TITLES[idx] || TITLES[0];
      img.style.opacity = '1';
      imgTitle.style.opacity = '1';
    }, 180);
  }

  // IntersectionObserver: activa el item que cruza la franja central
  const io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        const idx = parseInt(e.target.dataset.index, 10);
        activate(idx);
      }
    });
  }, {
    root: null,
    rootMargin: '-25% 0px -55% 0px',
    threshold: 0
  });

  items.forEach(function (item) { io.observe(item); });

  // Click también activa
  items.forEach(function (item) {
    item.addEventListener('click', function () {
      activate(parseInt(item.dataset.index, 10));
    });
  });

  // Hover: resalta temporalmente el texto sin cambiar el "active" real
  items.forEach(function (item) {
    item.addEventListener('mouseenter', function () {
      const title = item.querySelector('.diff-item-title');
      if (!item.classList.contains('active')) {
        title.classList.add('text-white/55');
      }
    });
    item.addEventListener('mouseleave', function () {
      const title = item.querySelector('.diff-item-title');
      if (!item.classList.contains('active')) {
        title.classList.remove('text-white/55');
      }
    });
  });

  // Init
  activate(0);
})();
</script>