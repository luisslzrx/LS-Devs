<!-- CTA -->
<section id="cta">
  <div class="mx-auto py-12 lg:py-16">
    <!-- Contenedor glass principal -->
    <div
      class="glass-container relative overflow-hidden rounded-4xl px-6 py-12 lg:px-20 lg:py-16 flex flex-col items-center text-center"
    >
      <!-- Shimmer overlay -->
      <div
        class="absolute inset-0 rounded-3xl pointer-events-none"
        style="background: linear-gradient(145deg, rgba(255,255,255,0.07) 0%, transparent 50%, rgba(255,255,255,0.02) 100%);"
      >
      </div>

      <!-- Línea de acento superior -->
      <div
        class="absolute top-0 left-1/10 right-1/10 h-0.5"
        style="background: linear-gradient(90deg, transparent, rgba(79,163,255,0.60), rgba(56,217,192,0.50), transparent);"
      >
      </div>

      <!-- Glow central difuso de fondo -->
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-48 lg:w-96 lg:h-72 rounded-full pointer-events-none"
        style="background: radial-gradient(ellipse, rgba(45,133,240,0.12) 0%, transparent 70%); filter: blur(40px);"
      >
      </div>

      <!-- Tag -->
      <div
        class="relative inline-flex items-center gap-2 text-xs font-bold tracking-wider uppercase text-blue-400 mb-4 lg:mb-6 px-4 py-2 rounded-full"
        style="background: rgba(79,163,255,0.10); border: 1px solid rgba(79,163,255,0.25);"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 shrink-0"></span>
        Empecemos hoy
      </div>

      <!-- Título -->
      <h2
        class="relative text-3xl lg:text-5xl font-black tracking-tight leading-tight text-blue-50 mb-4 lg:mb-5 max-w-lg lg:max-w-2xl"
      >
        Tu próximo sitio web<br />
        <span class="text-gradient"> empieza aquí </span>
      </h2>

      <!-- Subtítulo -->
      <p
        class="relative text-sm lg:text-base text-white/70 leading-relaxed max-w-md lg:max-w-xl mb-8 lg:mb-10"
      >
        Cuéntame tu proyecto hoy y en menos de 24 horas tendrás una propuesta
        personalizada, sin costo y sin compromiso.
      </p>

      <!-- CTAs -->
      <div
        class="relative flex gap-3 lg:gap-4 flex-wrap items-center justify-center mb-8 lg:mb-10"
      >
        <!-- Primario -->
        <a
          href="#contacto"
          class="btn-glass-highlight relative overflow-hidden inline-flex items-center gap-2 font-bold text-sm px-6 lg:px-8 py-3 lg:py-4 rounded-full text-white transition-transform duration-200 hover:-translate-y-0.5"
          style="background: linear-gradient(135deg, rgba(45,133,240,0.88) 0%, rgba(18,86,199,0.92) 100%); backdrop-filter: blur(20px) saturate(180%); border: 1px solid rgba(79,163,255,0.45); box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);"
        >
          Cotizar gratis
        </a>

        <!-- Ghost -->
        <a
          href="/proyectos"
          class="btn-glass-highlight relative overflow-hidden inline-flex items-center gap-2 font-bold text-sm px-6 lg:px-8 py-3 lg:py-4 rounded-full text-blue-50 transition-transform duration-200 hover:-translate-y-0.5 hover:bg-white/10"
          style="background: rgba(255,255,255,0.07); backdrop-filter: blur(24px) saturate(160%); border: 1px solid rgba(255,255,255,0.18); box-shadow: inset 0 1px 0 rgba(255,255,255,0.10);"
        >
          Ver proyectos →
        </a>
      </div>

      <!-- Trust strip -->
      <div
        class="relative flex items-center gap-3 lg:gap-6 flex-wrap justify-center"
      >
        <div
          class="flex items-center gap-2 px-3 lg:px-4 py-2 rounded-full"
          style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);"
        >
          <svg
            class="w-3 h-3 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#4ade80"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="text-xs font-semibold text-white/60"
            >Respuesta en menos de 24h</span
          >
        </div>

        <div
          class="flex items-center gap-2 px-3 lg:px-4 py-2 rounded-full"
          style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);"
        >
          <svg
            class="w-3 h-3 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#4ade80"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="text-xs font-semibold text-white/60"
            >Sin costo ni compromiso</span
          >
        </div>

        <div
          class="flex items-center gap-2 px-3 lg:px-4 py-2 rounded-full"
          style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);"
        >
          <svg
            class="w-3 h-3 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#4ade80"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span class="text-xs font-semibold text-white/60"
            >+20 proyectos entregados</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
