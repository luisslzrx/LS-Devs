---
import DarkModeIcon from "./icons/DarkModeIcon.astro";
---

<button
  id="theme-toggle"
  class="p-2 rounded-lg bg-transparent hover:bg-white/20 dark:hover:bg-black/20 transition-colors"
  aria-label="Cambiar tema"
>
  <!-- Icono de sol para modo oscuro (cambiar a claro) -->
  <svg class="w-6 h-6 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
    <circle cx="12" cy="12" r="5"/>
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
  </svg>
  <!-- Icono de luna para modo claro (cambiar a oscuro) -->
  <DarkModeIcon class="w-6 h-6 block dark:hidden" fill="currentColor" />
</button>

<script>
  const themeToggle = document.getElementById("theme-toggle");
  const html = document.documentElement;

  // Función para aplicar tema
  function applyTheme(theme) {
    if (theme === "light") {
      html.classList.remove("dark");
      html.classList.add("light");
      html.setAttribute("data-theme", "light");
    } else {
      html.classList.remove("light");
      html.classList.add("dark");
      html.setAttribute("data-theme", "dark");
    }
    localStorage.setItem("theme", theme);
  }

  // Por defecto: tema claro
  const defaultTheme = "light";

  // Verificar tema guardado o usar el por defecto
  const savedTheme = localStorage.getItem("theme");
  const currentTheme = savedTheme || defaultTheme;

  // Aplicar tema inicial
  applyTheme(currentTheme);

  // Cambiar tema al hacer clic
  if (themeToggle) {
    themeToggle.addEventListener("click", () => {
      const isDark = html.classList.contains("dark");
      const newTheme = isDark ? "light" : "dark";
      applyTheme(newTheme);
    });
  }
</script>
