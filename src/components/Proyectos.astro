---
import ExperienciaIcon from './icons/experiencia-icon.astro';

interface Proyecto {
  title: string;
  description: string;
  category: string;
  image: string;
  gradient: string;
  tags: string[];
  url: string;
}

const PROYECTOS: Proyecto[] = [
{
  title: "Drake Abogados – Sitio Web Informativo",
  description: "Sitio web informativo para despacho jurídico. Presentación de servicios legales y contacto con clientes. Desarrollado con WordPress y Elementor. Diseño responsive y estructura optimizada.",
  category: "Web Development",
  image: "/drake-abogados.webp",
  gradient: "from-blue-400 to-indigo-600",
  tags: ["WordPress", "Elementor", "Responsive Design"],
  date: "December 2025",
  url: "https://drakeabogados.com/"
},
{
  title: "ZDS Abogados – Landing Page",
  description: "Landing page para despacho legal enfocada en captación de clientes. Diseño claro y directo. Desarrollada con WordPress y Elementor. Optimizada para dispositivos móviles.",
  category: "Web Development",
  image: "/alvaro.webp",
  gradient: "from-purple-400 to-indigo-600",
  tags: ["WordPress", "Elementor", "Landing Page"],
  date: "December 2025",
  url: "https://zdsabogados.com/"
},

{
  title: "Estancia Escolar – Landing Page",
  description: "Landing page para una estancia escolar enfocada en informar servicios educativos y facilitar el contacto con padres de familia. Desarrollada con Astro, HTML, CSS, JavaScript y Tailwind CSS. Optimizada para dispositivos móviles.",
  category: "Web Development",
  image: "/estancia-escolar.webp",
  gradient: "from-cyan-400 to-blue-600",
  tags: ["Astro", "Tailwind CSS", "HTML", "JavaScript"],
  date: "2026",
  url: "https://estancia-escolar.luissalazar.com.mx/"
}
];
---

<section class="">
  <div class="flex items-center gap-2 mb-8 -ml-2">
        <ExperienciaIcon class="w-6 h-6 fill-white" />
        <h2 class="text-3xl font-bold ">Acerca de mí</h2>
    </div>

  <div class="space-y-20 max-w-6xl mx-auto">
    
    {PROYECTOS.map((proyecto) => (
      <article class="flex flex-col md:flex-row gap-8 items-start">
        <a href={proyecto.url} target="_blank" class="w-full md:w-1/2 rounded-xl overflow-hidden shadow-2xl flex items-center justify-center group hover:scale-105 transition-transform">
          <img src={proyecto.image} alt={proyecto.title} class="w-full h-auto object-cover">
        </a>
        
        <div class="w-full md:w-1/2 space-y-4">
          <h3 class="text-2xl font-bold leading-tight">{proyecto.title}</h3>
          
          <div class="flex gap-2">
            <span class="flex items-center gap-1 bg-black border border-white/20 px-3 py-1 rounded-full text-xs font-medium text-gray-300">
              <span class="w-2 h-2 bg-white rounded-full"></span> {proyecto.category}
            </span>
            {proyecto.tags.slice(0, 2).map((tag) => (
              <span class="flex items-center gap-1 bg-[#003159] border border-[#00d8ff]/30 px-3 py-1 rounded-full text-xs font-medium text-[#00d8ff]">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12.001 4.8c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8.913.228 1.565.89 2.288 1.624C13.666 10.618 15.027 12 18.201 12c3.2 0 5.2-1.6 6-4.8-1.2 1.6-2.6 2.2-4.2 1.8-.913-.228-1.565-.89-2.288-1.624C16.537 6.182 15.176 4.8 12.001 4.8z"/></svg>
                {tag}
              </span>
            ))}
          </div>

          <p class="leading-relaxed">
            {proyecto.description}
          </p>
        </div>
      </article>
    ))}

  </div>
</section>