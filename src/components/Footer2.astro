---
import AboutContent from "./about2.astro";
import ServicesContent from "./servicios2.astro";
import PricesContent from "./Prices2.astro";
import ProyectosContent from "./Proyectos2.astro";
import BenefitsContent from "./Beneficios2.astro";
import TestimonialsContent from "./Testimonios.astro";
import ContactContent from "./Contacto2.astro";

//Iconos
import AcercaDeMiIcon from "./icons/AcercaDeMi-Icon.astro";
import BeneficiosIcon from "./icons/Beneficios-Icon.astro";
import TestimoniosIcon from "./icons/Testimoniales-Icon.astro";
import PortafolioIcon from "./icons/Portafolio-Icon.astro";
import PreciosIcon from "./icons/Precios-Icon.astro";
import ContactoIcon from "./icons/Contacto-Icon.astro";
import ServiciosIcon from "./icons/Servicios-Icon.astro";
---

<!-- BOTTOM NAV -->
<footer class="fixed bottom-0 left-0 right-0 z-50 w-full">
  <!-- Botones de navegación (ocultos en móvil) -->
  <nav class="hidden md:flex items-end justify-around px-4 py-5 bg-gradient-to-t from-black via-black/80 to-transparent">
    <div class="w-full max-w-[1100px] mx-auto flex items-end justify-around">

    <!-- Acerca de mi -->
    <button
      onclick="openAboutPopup()"
      class="group flex-1 flex flex-col items-center gap-1.5 pt-2 px-1 pb-1 bg-transparent border-none cursor-pointer
             -translate-y-0 hover:-translate-y-[5px] active:-translate-y-[2px]
             transition-transform duration-200 [transition-timing-function:cubic-bezier(0.34,1.56,0.64,1)]"
    >
      <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                   text-white/70 bg-transparent
                   transition-all duration-200
                   group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                   group-active:scale-95">
        <AcercaDeMiIcon class="w-6 h-6" />
      </span>
      <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                   transition-colors duration-200 group-hover:text-white/95">About</span>
    </button>

    <!-- Servicios -->
    <button
      onclick="openServicesPopup()"
      class="group flex-1 flex flex-col items-center gap-1.5 pt-2 px-1 pb-1 bg-transparent border-none cursor-pointer
             -translate-y-0 hover:-translate-y-[5px] active:-translate-y-[2px]
             transition-transform duration-200 [transition-timing-function:cubic-bezier(0.34,1.56,0.64,1)]"
    >
      <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                   text-white/70 bg-transparent
                   transition-all duration-200
                   group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                   group-active:scale-95">
        <ServiciosIcon class="w-6 h-6" />
      </span>
      <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                   transition-colors duration-200 group-hover:text-white/95">Services</span>
    </button>


      <!-- Beneficios -->
    <button
      onclick="openBenefitsPopup()"
      class="group flex-1 flex flex-col items-center gap-1.5 pt-2 px-1 pb-1 bg-transparent border-none cursor-pointer
             -translate-y-0 hover:-translate-y-[5px] active:-translate-y-[2px]
             transition-transform duration-200 [transition-timing-function:cubic-bezier(0.34,1.56,0.64,1)]"
    >
      <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                   text-white/70 bg-transparent
                   transition-all duration-200
                   group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                   group-active:scale-95">
        <BeneficiosIcon class="w-6 h-6" />
      </span>
      <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                   transition-colors duration-200 group-hover:text-white/95">Beneficios</span>
    </button>


    <!-- Portafolio -->
    <button
      onclick="openGalleryPopup()"
      class="group flex-1 flex flex-col items-center gap-1.5 pt-2 px-1 pb-1 bg-transparent border-none cursor-pointer
             -translate-y-0 hover:-translate-y-[5px] active:-translate-y-[2px]
