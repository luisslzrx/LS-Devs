  }

  function openBenefitsPopup() {
    const popup = document.getElementById('benefitsPopup');
    if (popup) {
      popup.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        const overlay = popup.querySelector('.popup-overlay');
