                   text-white/70 bg-transparent
                   transition-all duration-200
                   group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                   group-active:scale-95">
        <PreciosIcon class="w-6 h-6" />
      </span>
      <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                   transition-colors duration-200 group-hover:text-white/95">Precios</span>
    </button>


    <!-- Testimoniales -->
    <button
      onclick="openTestimonialsPopup()"
      class="group flex-1 flex flex-col items-center gap-1.5 pt-2 px-1 pb-1 bg-transparent border-none cursor-pointer
             -translate-y-0 hover:-translate-y-[5px] active:-translate-y-[2px]
             transition-transform duration-200 [transition-timing-function:cubic-bezier(0.34,1.56,0.64,1)]"
    >
      <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                   text-white/70 bg-transparent
                   transition-all duration-200
                   group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                   group-active:scale-95">
        <TestimoniosIcon class="w-6 h-6" />
      </span>
      <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                   transition-colors duration-200 group-hover:text-white/95">Testimonios</span>
    </button>


    <!-- Contacto -->
    <button
      onclick="openContactPopup()"
      class="group flex-1 flex flex-col items-center gap-1.5 pt-2 px-1 pb-1 bg-transparent border-none cursor-pointer
             -translate-y-0 hover:-translate-y-[5px] active:-translate-y-[2px]
             transition-transform duration-200 [transition-timing-function:cubic-bezier(0.34,1.56,0.64,1)]"
    >
      <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                   text-white/70 bg-transparent
                   transition-all duration-200
                   group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                   group-active:scale-95">
        <ContactoIcon class="w-6 h-6" />
      </span>
      <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                   transition-colors duration-200 group-hover:text-white/95">Contacto</span>
    </button>

    </div>
  </nav>

  <!-- Copyright (visible solo en móvil) -->
  <div class="md:hidden py-3 bg-black/80 text-center">
    <p class="text-white/60 text-xs">© 2024 LS Studio. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  /* Solo estados JS-toggled de popups */
  .popup-overlay {
    opacity: 0;
    transition: opacity 0.2s ease-out;
  }
  .popup-overlay.show { opacity: 1; }

  .popup-content {
    transform: scale(0.9) translateY(20px);
    opacity: 0;
    transition: all 0.3s ease-out;
  }
  .popup-content.show {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
</style>

<!-- Popup About -->
<div id="aboutPopup" class="fixed inset-0 z-[60] hidden">
  <!-- Overlay -->
  <div 
    class="popup-overlay absolute inset-0 bg-black/60 backdrop-blur-sm"
    onclick="closeAboutPopup()"
  ></div>
  
  <!-- Contenedor del contenido -->
  <div class="relative flex items-center justify-center min-h-screen p-4">
    <div class="popup-content">
      <AboutContent client:load />
    </div>
  </div>
</div>

<!-- Popup Services -->
<div id="servicesPopup" class="fixed inset-0 z-[60] hidden">
  <!-- Overlay -->
  <div 
    class="popup-overlay absolute inset-0 bg-black/60 backdrop-blur-sm"
    onclick="closeServicesPopup()"
  ></div>
  
  <!-- Contenedor del contenido -->
  <div class="relative flex items-center justify-center min-h-screen p-4">
    <div class="popup-content">
      <ServicesContent client:load />
    </div>
  </div>
</div>

<!-- Popup Precios -->
<div id="pricingPopup" class="fixed inset-0 z-[60] hidden">
  <!-- Overlay -->
  <div 
    class="popup-overlay absolute inset-0 bg-black/60 backdrop-blur-sm"
    onclick="closePricingPopup()"
  ></div>
  
  <!-- Contenedor del contenido -->
  <div class="relative flex items-center justify-center min-h-screen p-4">
    <div class="popup-content">
      <PricesContent client:load />
    </div>
  </div>
</div>

<!-- Popup Portafolio -->
<div id="galleryPopup" class="fixed inset-0 z-[60] hidden">
  <!-- Overlay -->
  <div 
    class="popup-overlay absolute inset-0 bg-black/60 backdrop-blur-sm"
    onclick="closeGalleryPopup()"
  ></div>
  
  <!-- Contenedor del contenido -->
  <div class="relative flex items-center justify-center min-h-screen p-4">
    <div class="popup-content">
      <ProyectosContent client:load />
    </div>
  </div>
</div>

<!-- Popup Beneficios -->
<div id="benefitsPopup" class="fixed inset-0 z-[60] hidden">
  <!-- Overlay -->
  <div 
    class="popup-overlay absolute inset-0 bg-black/60 backdrop-blur-sm"
    onclick="closeBenefitsPopup()"
  ></div>
  
  <!-- Contenedor del contenido -->
  <div class="relative flex items-center justify-center min-h-screen p-4">
    <div class="popup-content">
      <BenefitsContent client:load />
