<section id="proceso">
  <div class="max-w-6xl mx-auto py-16 lg:py-[90px]">
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-8 lg:gap-[80px] items-start"
    >
      <!-- Columna izquierda — texto y CTAs -->
      <div>
        <!-- Tag -->
        <div
          class="inline-flex items-center gap-2 text-xs font-bold tracking-wider uppercase text-blue-400 mb-4 lg:mb-[22px] px-4 py-2 rounded-full glass-tag"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 shrink-0"></span>
          Proceso
        </div>

        <h2
          class="text-2xl lg:text-[2.3rem] font-extrabold tracking-tight leading-tight text-blue-50 mb-4"
        >
          Cuatro pasos hacia tu sitio web perfecto
        </h2>

        <p
          class="text-sm lg:text-[0.95rem] text-white/75 leading-relaxed lg:leading-[1.70] mb-6 lg:mb-[38px]"
        >
          Desde la primera conversación hasta la entrega final, guiamos cada
          etapa con precisión y claridad.
        </p>

        <!-- CTAs -->
        <div class="flex gap-3 lg:gap-3.5 flex-wrap">
          <!-- Botón primario -->
          <a
            href="#contacto"
            class="btn-glass-highlight relative overflow-hidden inline-flex items-center gap-2 lg:gap-2.5 font-bold text-sm lg:text-base px-6 lg:px-[30px] py-3.5 rounded-full text-white transition-transform duration-200 hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, rgba(45,133,240,0.85) 0%, rgba(18,86,199,0.90) 100%); backdrop-filter: blur(20px) saturate(180%); border: 1px solid rgba(79,163,255,0.40); box-shadow: inset 0 1px 0 rgba(255,255,255,0.20);"
          >
            Comenzar ahora
          </a>

          <!-- Botón ghost -->
          <a
            href="/proyectos"
            class="btn-glass-highlight relative overflow-hidden inline-flex items-center gap-2 lg:gap-2.5 font-bold text-sm lg:text-base px-6 lg:px-[30px] py-3.5 rounded-full text-blue-50 transition-transform duration-200 hover:-translate-y-0.5 hover:bg-white/11"
            style="background: rgba(255,255,255,0.07); backdrop-filter: blur(24px) saturate(160%); border: 1px solid rgba(255,255,255,0.18); box-shadow: inset 0 1px 0 rgba(255,255,255,0.10);"
          >
            Ver proyectos →
          </a>
        </div>
      </div>

      <!-- Columna derecha — pasos -->
      <div class="flex flex-col pt-2">
        <!-- Paso 1 -->
        <div
          class="proc-row-connector relative flex gap-4 lg:gap-[22px] items-start px-4 lg:px-5 py-4 lg:py-5 rounded-xl lg:rounded-[14px] transition-colors duration-200 hover:bg-white/4 group"
        >
          <div
            class="w-10 h-10 lg:w-[42px] lg:h-[42px] rounded-full shrink-0 flex items-center justify-center text-sm lg:text-base font-extrabold text-blue-400 transition-transform duration-200 group-hover:scale-105 relative z-10"
            style="background: rgba(255,255,255,0.06); backdrop-filter: blur(16px); border: 1px solid rgba(79,163,255,0.25);"
          >
            01
          </div>
          <div class="pt-2 lg:pt-[9px]">
            <div
              class="text-sm lg:text-base font-bold text-blue-50 mb-1 lg:mb-[5px]"
            >
              Contacto y consulta
            </div>
            <div
              class="text-xs lg:text-sm text-white/75 leading-relaxed lg:leading-[1.60]"
            >
              Hablamos sobre tu visión, objetivos y presupuesto disponible. Sin
              compromisos, sin costos.
            </div>
          </div>
        </div>

        <!-- Paso 2 — activo -->
        <div
          class="proc-row-connector relative flex gap-4 lg:gap-[22px] items-start px-4 lg:px-5 py-4 lg:py-5 rounded-xl lg:rounded-[14px] transition-colors duration-200 hover:bg-white/4 group"
        >
          <div
            class="w-10 h-10 lg:w-[42px] lg:h-[42px] rounded-full shrink-0 flex items-center justify-center text-sm lg:text-base font-extrabold text-blue-400 transition-transform duration-200 group-hover:scale-105 relative z-10"
            style="background: rgba(255,255,255,0.06); backdrop-filter: blur(16px); border: 1px solid rgba(79,163,255,0.25);"
          >
            02
          </div>
          <div class="pt-2 lg:pt-[9px]">
            <div
              class="text-sm lg:text-base font-bold text-blue-50 mb-1 lg:mb-[5px]"
            >
              Diseño y estrategia
            </div>
            <div
              class="text-xs lg:text-sm text-white/75 leading-relaxed lg:leading-[1.60]"
            >
              Creamos mockups modernos que reflejan tu marca y están diseñados
              para atraer clientes.
            </div>
          </div>
        </div>

        <!-- Paso 3 -->
        <div
          class="proc-row-connector relative flex gap-4 lg:gap-[22px] items-start px-4 lg:px-5 py-4 lg:py-5 rounded-xl lg:rounded-[14px] transition-colors duration-200 hover:bg-white/4 group"
        >
          <div
            class="w-10 h-10 lg:w-[42px] lg:h-[42px] rounded-full shrink-0 flex items-center justify-center text-sm lg:text-base font-extrabold text-blue-400 transition-transform duration-200 group-hover:scale-105 relative z-10"
            style="background: rgba(255,255,255,0.06); backdrop-filter: blur(16px); border: 1px solid rgba(79,163,255,0.25);"
          >
            03
          </div>
          <div class="pt-2 lg:pt-[9px]">
            <div
              class="text-sm lg:text-base font-bold text-blue-50 mb-1 lg:mb-[5px]"
            >
              Desarrollo y construcción
            </div>
            <div
              class="text-xs lg:text-sm text-white/75 leading-relaxed lg:leading-[1.60]"
            >
              Codificamos tu sitio con tecnología actual, rápido, seguro y
              optimizado para buscadores.
            </div>
          </div>
        </div>

        <!-- Paso 4 — sin conector -->
        <div
          class="relative flex gap-4 lg:gap-[22px] items-start px-4 lg:px-5 py-4 lg:py-5 rounded-xl lg:rounded-[14px] transition-colors duration-200 hover:bg-white/4 group"
        >
          <div
            class="w-10 h-10 lg:w-[42px] lg:h-[42px] rounded-full shrink-0 flex items-center justify-center text-sm lg:text-base font-extrabold text-blue-400 transition-transform duration-200 group-hover:scale-105 relative z-10"
            style="background: rgba(255,255,255,0.06); backdrop-filter: blur(16px); border: 1px solid rgba(79,163,255,0.25);"
          >
            04
          </div>
          <div class="pt-2 lg:pt-[9px]">
            <div
              class="text-sm lg:text-base font-bold text-blue-50 mb-1 lg:mb-[5px]"
            >
              Entrega y soporte
            </div>
            <div
              class="text-xs lg:text-sm text-white/75 leading-relaxed lg:leading-[1.60]"
            >
              Tu sitio vive en línea. Capacitación incluida y soporte
              post-lanzamiento para que todo funcione perfecto.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
