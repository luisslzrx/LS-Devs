---
import LinkedlnIcon from "./icons/Linkedln-icon.astro";
import WorkIcon from "./icons/work-icon.astro";

interface Experiencia {
  puesto: string;
  empresa: string;
  fecha: string;
  descripcion: string;
}

const EXPERIENCIA: Experiencia[] = [
  {
    puesto: "1. Cuéntame tu idea",
    empresa: "",
    fecha: "",
    descripcion: "Me explicas qué necesitas y qué objetivo tienes"
  },
  {
    puesto: "2. Propuesta y cotización",
    empresa: "",
    fecha: "",
    descripcion: "Te doy una solución clara con precio y tiempos"
  },
  {
    puesto: "3. Diseño y desarrollo",
    empresa: "",
    fecha: "",
    descripcion: "Creo tu página web enfocada en resultados"
  },
  {
    puesto: "4. Entrega y publicación",
    empresa: "",
    fecha: "",
    descripcion: "Tu sitio queda listo para usarse y empezar a vender"
  }
];
---

<article class="container px-2 mt-10 min-h-[600px] flex flex-col justify-center">

    <h2 class="text-3xl md:text-4xl font-bold text-center mb-6">
      Servicios que <span class="text-blue-400">ofrezco</span>
    </h2>

    <p class="text-gray-400 text-center max-w-2xl mx-auto mb-12">
      ¿Buscas un sitio web profesional que se vea bien, funcione correctamente
      y tenga presencia real en internet?
    </p>
    
  <div class="relative">
    <!-- Línea horizontal -->
    <div class="absolute top-4 left-0 right-0 h-0.5 bg-slate-300"></div>
    
    <!-- Contenedor de pasos -->
    <div class="relative flex justify-between items-start gap-4">
      {EXPERIENCIA.map((item, index) => (
        <div class="flex flex-col items-center text-center max-w-xs">
          <!-- Círculo del paso -->
          <span class="relative flex items-center justify-center w-8 h-8 bg-slate-700 rounded-full ring-2 ring-slate-100 mb-4 z-10">
            <span class="text-white font-bold text-sm">{index + 1}</span>
          </span>
          
          <!-- Contenido del paso -->
          <div class="mt-4 p-4">
            <h3 class="text-lg font-semibold text-cyan-400 mb-2">
              {item.puesto}
            </h3>
            <p class="text-gray-300">
              {item.descripcion}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</article>