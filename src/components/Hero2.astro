---
// HeroSection.astro
import WhatsappIcon from "./icons/WhatsappIcon.astro";
import MailIcon from "./icons/MailIcon.astro";
---

<section
  class="relative w-full h-screen min-h-[600px] sm:h-[100vh] overflow-hidden flex flex-col"
>
  <!-- Video de fondo -->
  <div class="absolute inset-0 z-0">
    <video
      src="/Video/video.mp4"
      autoplay
      loop
      muted
      playsinline
      class="w-full h-full object-cover object-center"></video>
    <!-- Overlay sutil para mejorar legibilidad del texto -->
    <div class="absolute inset-0 bg-pink-500/10"></div>
  </div>

  <!-- CONTENIDO CENTRAL -->
  <main
    class="relative z-10 flex flex-1 flex-col items-center justify-center text-center px-4 sm:px-6 lg:max-w-4xl mx-auto"
  >
    <h1
      class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight drop-shadow-2xl animate-fade-in-up"
    >
      Desarrollo paginas web profesionales para tu negocio
    </h1>

    <h2
      class="mt-6 sm:mt-8 max-w-2xl text-white/90 text-base sm:text-lg md:text-xl leading-relaxed font-medium px-2 animate-fade-in-up delay-200"
    >
      Diseño y desarrollo landing pages, sitios corporativos y tiendas en línea
      que transforman visitantes en clientes reales. Moderno, rápido y enfocado
      en resultados.
  </h2>

    <div class="mt-8 sm:mt-12 flex flex-row gap-3 sm:gap-4 items-center justify-center">
      <a
        href="/proyectos"
        class="px-8 py-3 sm:px-10 sm:py-4 bg-white text-gray-900 font-bold text-xs sm:text-sm tracking-widest rounded-full
               shadow-2xl hover:bg-pink-50 hover:scale-110 active:scale-95
               transition-all duration-300 ease-out cursor-pointer inline-block animate-scale-in"
      >
        Ver proyectos
      </a>
      <a
        href="https://wa.me/522288535112?text=Hola,%20quiero%20una%20cotización"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center w-12 h-12 rounded-full hover:scale-115 active:scale-95
               transition-all duration-300 ease-out cursor-pointer  animate-scale-in glass-effect"
      >
        <WhatsappIcon class="w-6 h-6" />
      </a>
      <a
        href="mailto:contacto@geradev.com.mx"
        class="flex items-center justify-center w-12 h-12 rounded-full hover:scale-115 active:scale-95
               transition-all duration-300 ease-out cursor-pointer  animate-scale-in glass-effect"
      >
        <MailIcon class="w-6 h-6" />
      </a>
    </div>
  </main>
</section>
