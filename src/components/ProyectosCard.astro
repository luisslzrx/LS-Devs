---
const { title, image, link, tags = [], description, date } = Astro.props;
---

<div class="snap-start flex-shrink-0 w-[85vw] sm:w-[370px] md:w-[700px] h-[300px] sm:h-[450px] md:h-[500px] bg-[#1d1d1f] rounded-3xl overflow-hidden flex flex-col relative">
  <!-- Text top -->
  <div class="p-6 pb-2">
    <p class="text-sm text-[#a1a1a6] mb-1">{tags[0] || 'Proyecto'}</p>
    <h3 class="text-2xl font-bold text-white leading-snug">
      {title}
    </h3>
  </div>
  <!-- Image fills rest -->
  <div class="flex-1 relative mt-4">
    <img
      src={image}
      alt={title}
      class="absolute inset-0 w-full h-full object-cover object-top"
    />
  </div>
</div>
