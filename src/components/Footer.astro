---
import LinkedinIcon from "./icons/LinkedinIcon.astro";
import GithubIcon from "./icons/GithubIcon.astro";
import WhatsappIcon from "./icons/WhatsappIcon.astro";
import InstagramIcon from "./icons/InstagramIcon.astro";
import FacebookIcon from "./icons/FacebookIcon.astro";
---

<!-- Pill flotante (siempre visible) -->
<div
  id="footerPill"
  class="fixed bottom-5 left-1/2 z-50 transition-all duration-500 ease-[cubic-bezier(.4,0,.2,1)]"
>
  <div
    id="pillInner"
    class="flex items-center gap-4 px-5 py-3 rounded-full transition-all duration-500"
    style="
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.15);
      box-shadow: 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.15);
    "
  >
    <span class="text-sm font-bold text-white whitespace-nowrap"
      >Luis Salazar</span
    >

    <div class="w-px h-4 bg-white/20"></div>

    <a
      href="https://www.linkedin.com/in/luis-gerardo-salazar-aguilar/"
      target="_blank"
      class="text-white/60 hover:text-white transition-colors duration-200"
    >
      <LinkedinIcon class="w-4 h-4" />
    </a>
    <a
      href="https://github.com/luisslzrx"
      target="_blank"
      class="text-white/60 hover:text-white transition-colors duration-200"
    >
      <GithubIcon class="w-4 h-4" />
    </a>
    <a
      href="https://www.instagram.com/geradevx/"
      target="_blank"
      class="text-white/60 hover:text-white transition-colors duration-200"
    >
      <InstagramIcon class="w-4 h-4" />
    </a>
    <a
      href="https://www.facebook.com/people/Geradev/61590062657544/"
      target="_blank"
      class="text-white/60 hover:text-white transition-colors duration-200"
    >
      <FacebookIcon class="w-4 h-4" />
    </a>

    <div class="w-px h-4 bg-white/20"></div>

    <a
      href="#contacto"
      class="text-sm font-semibold text-[#50C1FC] hover:text-white transition-colors duration-200 whitespace-nowrap"
    >
      Contáctanos
    </a>
  </div>
</div>

<!-- Footer completo (aparece al llegar al final) -->
<footer
  id="fullFooter"
  class="w-full px-6 pt-6 pb-6 md:px-12 lg:px-20 opacity-0 translate-y-8 transition-all duration-700 ease-[cubic-bezier(.4,0,.2,1)] pointer-events-none"
  style="border-top: 1px solid rgba(255,255,255,0.06);"
>  <!-- Links grid - 3 columnas -->
  <div class="grid grid-cols-1 md:grid-cols-3 mb-16 gap-10 md:gap-4">
    <!-- Columna 1: Nombre y descripción -->
    <div class="text-center md:text-left">
      <p class="text-3xl md:text-4xl font-bold text-white mb-3 leading-tight">
        Geradev<span class="text-[#50C1FC]">.</span>
      </p>
      <p class="text-sm text-white/40 leading-relaxed max-w-sm mx-auto md:mx-0">
        Desarrollo web profesional enfocado en diseño, rendimiento y resultados
        reales.
      </p>
    </div>

    <!-- Columna 2: Redes sociales -->
    <div class="flex flex-col items-center">
      <p
        class="text-xs font-semibold text-white/30 uppercase tracking-widest mb-4"
      >
        Redes Sociales
      </p>
      <ul class="flex flex-wrap gap-4 justify-center">
        <li>
          <a
            href="https://wa.me/525632193996"
            target="_blank"
            class="footer-link text-white/50 hover:text-white transition-colors duration-200 flex items-center gap-2"
          >
            <WhatsappIcon class="w-5 h-5" />
          </a>
        </li>
        <li>
          <a
            href="https://www.facebook.com/people/Geradev/61590062657544/"
            target="_blank"
            class="footer-link text-white/50 hover:text-white transition-colors duration-200 flex items-center gap-2"
          >
            <FacebookIcon class="w-5 h-5" />
          </a>
        </li>
        <li>
          <a
            href="https://www.instagram.com/geradevx/"
            target="_blank"
            class="footer-link text-white/50 hover:text-white transition-colors duration-200 flex items-center gap-2"
          >
            <InstagramIcon class="w-5 h-5" />
          </a>
        </li>
        <li>
          <a
            href="https://linkedin.com/in/luis-gerardo-salazar-aguilar"
            target="_blank"
            class="footer-link text-white/50 hover:text-white transition-colors duration-200 flex items-center gap-2"
          >
            <LinkedinIcon class="w-5 h-5" />
          </a>
        </li>
        <li>
          <a
            href="https://github.com/luisslzrx"
            target="_blank"
            class="footer-link text-white/50 hover:text-white transition-colors duration-200 flex items-center gap-2"
          >
            <GithubIcon class="w-5 h-5" />
          </a>
        </li>
      </ul>
    </div>

    <!-- Columna 3: Botón de cotizar -->
    <div class="flex flex-col items-center justify-center">
      <p
        class="text-xs font-semibold text-white/30 uppercase tracking-wide mb-4"
      >
        ¿Listo para empezar?
      </p>
      <a
        href="#contacto"
        class="inline-flex items-center justify-center gap-2 px-6 py-4 rounded-full text-[#0d0d0d] text-sm font-bold bg-[#50C1FC] hover:bg-[#38b0f0] hover:scale-105 active:scale-95 transition-all duration-200 w-fit"
      >
        Cotizar Proyecto
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Divider -->
  <div style="border-top: 1px solid rgba(255,255,255,0.06);" class="mb-8 d-500">
  </div>

  <!-- Bottom bar -->
  <div
    class="flex flex-col md:flex-row items-center justify-between gap-4"
  >
    <p class="text-xs text-white/25 text-center md:text-left">
      &copy; <span id="footerYear"></span> Geradev · Luis Gerardo Salazar
    </p>

    <div class="flex items-center gap-4 justify-center">
      <a
        href="#"
        class="text-xs text-white/25 hover:text-white/60 transition-colors duration-200"
        >Privacidad</a
      >
      <a
        href="#"
        class="text-xs text-white/25 hover:text-white/60 transition-colors duration-200"
        >Términos</a
      >
    </div>
  </div>
</footer>

<style>
  .footer-link {
    position: relative;
    display: inline-block;
  }
  .footer-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: #50c1fc;
    transition: width 0.25s ease;
  }
  .footer-link:hover::after {
    width: 100%;
  }

  #fullFooter.revealed {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  #footerPill {
    translate: -50% 0;
  }

  /* Pill se desvanece y baja ligeramente cuando el footer está visible */
  #footerPill.hide-pill {
    opacity: 0;
    translate: -50% 10px;
    pointer-events: none;
  }
</style>

<script is:inline>
  (function () {
    const pill = document.getElementById("footerPill");
    const fullFooter = document.getElementById("fullFooter");
    const yearEl = document.getElementById("footerYear");
    if (yearEl) yearEl.textContent = new Date().getFullYear();

    function check() {
      // distancia desde el fondo de la página hasta el viewport
      const distFromBottom =
        document.documentElement.scrollHeight -
        window.scrollY -
        window.innerHeight;

      if (distFromBottom < 80) {
        fullFooter.classList.add("revealed");
        pill.classList.add("hide-pill");
      } else {
        fullFooter.classList.remove("revealed");
        pill.classList.remove("hide-pill");
      }
    }

    window.addEventListener("scroll", check, { passive: true });
    check();
  })();
</script>
