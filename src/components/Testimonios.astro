---
// Testimonials2.astro
// Componente de testimonios con carrusel — mismo estilo visual
---

<style>
  .testimonial-slide {
    transition: all 0.4s ease;
  }

  /* Ocultar scrollbar en el track */
  .slider-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .slider-track::-webkit-scrollbar {
    display: none;
  }
</style>

<div class="relative bg-white rounded-3xl w-full max-w-4xl mx-auto flex flex-col justify-center">

  <!-- Badge "Testimonials" -->
  <div class="absolute -top-4 left-6 z-20">
    <span class="bg-sky-400 text-white text-sm sm:text-xl font-bold px-4 sm:px-6 py-2 rounded-xl shadow-lg inline-block">
      Testimonios
    </span>
  </div>

  <!-- Botón cerrar -->
  <button
    onclick="closeTestimonialsPopup()"
    class="absolute top-4 right-4 z-20 w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-gray-900 text-white
           flex items-center justify-center hover:bg-gray-700 transition-colors duration-200 cursor-pointer"
    aria-label="Cerrar testimonios"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
    </svg>
  </button>

  <!-- Contenido -->
  <div class="pt-8 sm:pt-10 pb-6 sm:pb-8 px-4 sm:px-4">

    <!-- Área del carrusel -->
    <div class="relative flex items-center justify-center gap-2 sm:gap-4 px-2 sm:px-10 min-h-[300px] sm:min-h-[380px]">

      <!-- Flecha izquierda -->
      <button
        id="prev-testimonial"
        class="absolute left-0 sm:left-2 z-10 w-8 h-8 sm:w-9 sm:h-9 rounded-full border border-gray-200 bg-white flex items-center justify-center text-gray-400 hover:text-gray-700 hover:border-gray-300 transition-all shadow-sm cursor-pointer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
        </svg>
      </button>

      <!-- Cards visibles: anterior (ghost) + activa + siguiente (ghost) -->
      <div class="flex items-center justify-center gap-6 w-full">

        <!-- Card anterior (ghost) -->
        <div id="card-prev" class="hidden md:flex flex-col items-center gap-4 w-56 opacity-40 scale-90 flex-shrink-0 transition-all duration-400">
          <div class="w-20 h-20 rounded-full overflow-hidden border-4 border-white shadow-md flex-shrink-0">
            <img id="img-prev" src="/testimonials/client-4.jpg" alt="" class="w-full h-full object-cover" onerror="this.src='https://ui-avatars.com/api/?name=C&background=e0f2fe&color=0ea5e9&size=80'" />
          </div>
          <div class="text-center">
            <p id="quote-prev" class="text-gray-400 text-xs leading-relaxed mb-3 line-clamp-4">
              Consetetur sadipscing elitr, sed diam tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua.
            </p>
            <div class="border-t border-gray-100 pt-3">
              <p id="name-prev" class="text-gray-500 text-sm font-bold">Oupsum dolor</p>
              <p id="role-prev" class="text-gray-400 text-xs italic">Creative Director</p>
            </div>
          </div>
        </div>

        <!-- Card activa (principal) -->
        <div class="flex flex-col items-center gap-3 sm:gap-4 flex-shrink-0 w-64 sm:w-72">
          <!-- Avatar grande con sombra -->
          <div class="w-20 h-20 sm:w-28 sm:h-28 rounded-full overflow-hidden border-4 border-white shadow-xl -mb-2 z-10 flex-shrink-0">
            <img id="img-active" src="/testimonials/client-1.jpg" alt="" class="w-full h-full object-cover" onerror="this.src='https://ui-avatars.com/api/?name=L&background=e0f2fe&color=0ea5e9&size=112'" />
          </div>
          <!-- Card blanca con sombra -->
          <div class="bg-white rounded-2xl shadow-lg border border-gray-100 px-4 sm:px-8 pt-10 sm:pt-14 pb-5 sm:pb-7 text-center w-full -mt-8 sm:-mt-10">
            <p id="quote-active" class="text-gray-700 text-xs sm:text-sm leading-relaxed mb-3 sm:mb-5">
              Consetetur sadipscing elitr, sed diam tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua.
            </p>
            <div class="border-t border-gray-100 pt-3 sm:pt-5">
              <p id="name-active" class="text-gray-900 text-sm sm:text-base font-bold">Luis Salazar</p>
              <p id="role-active" class="text-gray-400 text-xs sm:text-sm italic">Desarrollador Web</p>
            </div>
          </div>
        </div>

        <!-- Card siguiente (ghost) -->
        <div id="card-next" class="hidden md:flex flex-col items-center gap-4 w-56 opacity-40 scale-90 flex-shrink-0 transition-all duration-400">
          <div class="w-20 h-20 rounded-full overflow-hidden border-4 border-white shadow-md flex-shrink-0">
            <img id="img-next" src="/testimonials/client-2.jpg" alt="" class="w-full h-full object-cover" onerror="this.src='https://ui-avatars.com/api/?name=A&background=e0f2fe&color=0ea5e9&size=80'" />
          </div>
          <div class="text-center">
            <p id="quote-next" class="text-gray-400 text-xs leading-relaxed mb-3 line-clamp-4">
              Consetetur sadipscing elitr, sed diam tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua.
            </p>
            <div class="border-t border-gray-100 pt-3">
              <p id="name-next" class="text-gray-500 text-sm font-bold">Ana García</p>
              <p id="role-next" class="text-gray-400 text-xs italic">CEO & Founder</p>
            </div>
          </div>
        </div>

      </div>

      <!-- Flecha derecha -->
      <button
        id="next-testimonial"
        class="absolute right-0 sm:right-2 z-10 w-8 h-8 sm:w-9 sm:h-9 rounded-full border border-gray-200 bg-white flex items-center justify-center text-gray-400 hover:text-gray-700 hover:border-gray-300 transition-all shadow-sm cursor-pointer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
        </svg>
      </button>

    </div>

    <!-- Dots -->
    <div id="dots-container" class="flex justify-center gap-1.5 sm:gap-2 mt-4 sm:mt-6">
      <!-- generados por JS -->
    </div>

    <!-- Footer copy -->
    <div class="text-center mt-6 sm:mt-8 px-4 sm:px-8">
      <h3 class="text-base sm:text-xl font-bold text-gray-900 mb-2">La satisfacción del cliente es lo más importante</h3>
      <p class="text-gray-400 text-xs sm:text-sm leading-relaxed max-w-lg mx-auto">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Quam dicta necessitatibus ratione itaque non animi vel.
      </p>
    </div>

  </div>

</div>

<script>
  const testimonials = [
    {
      img: "/testimonials/client-1.jpg",
      fallback: "L",
      quote: "Excelente trabajo, entregó el sitio antes de lo prometido y superó mis expectativas. El diseño quedó exactamente como lo visualicé.",
      name: "Luis Hernández",
      role: "Emprendedor",
    },
    {
      img: "/testimonials/client-2.jpg",
      fallback: "A",
      quote: "Muy profesional y con gran atención al detalle. Mi tienda en línea empezó a generar ventas desde la primera semana.",
      name: "Ana García",
      role: "CEO & Founder",
    },
    {
      img: "/testimonials/client-3.jpg",
      fallback: "M",
      quote: "Comunicación excelente durante todo el proyecto. Resolvió cada duda rápidamente y el resultado final fue increíble.",
      name: "Miguel Torres",
      role: "Director Creativo",
    },
    {
      img: "/testimonials/client-4.jpg",
      fallback: "S",
      quote: "Me ayudó a llevar mi negocio al siguiente nivel. La landing page convierte muy bien y el SEO mejoró notablemente.",
      name: "Sofía Ramírez",
      role: "Marketing Manager",
    },
  ];

  let current = 0;

  function mod(n: number, m: number) { return ((n % m) + m) % m; }

  function getAvatar(item: typeof testimonials[0]) {
    return `https://ui-avatars.com/api/?name=${item.fallback}&background=e0f2fe&color=0ea5e9&size=112`;
  }

  function updateCarousel() {
    const prev = mod(current - 1, testimonials.length);
    const next = mod(current + 1, testimonials.length);

    // Activa
    const imgA  = document.getElementById('img-active')    as HTMLImageElement;
    const qA    = document.getElementById('quote-active')!;
    const nA    = document.getElementById('name-active')!;
    const rA    = document.getElementById('role-active')!;
    imgA.src    = testimonials[current].img;
    imgA.onerror = () => { imgA.src = getAvatar(testimonials[current]); };
    qA.textContent = testimonials[current].quote;
    nA.textContent = testimonials[current].name;
    rA.textContent = testimonials[current].role;

    // Anterior
    const imgP  = document.getElementById('img-prev')  as HTMLImageElement;
    const qP    = document.getElementById('quote-prev')!;
    const nP    = document.getElementById('name-prev')!;
    const rP    = document.getElementById('role-prev')!;
    imgP.src    = testimonials[prev].img;
    imgP.onerror = () => { imgP.src = getAvatar(testimonials[prev]); };
    qP.textContent = testimonials[prev].quote;
    nP.textContent = testimonials[prev].name;
    rP.textContent = testimonials[prev].role;

    // Siguiente
    const imgN  = document.getElementById('img-next')  as HTMLImageElement;
    const qN    = document.getElementById('quote-next')!;
    const nN    = document.getElementById('name-next')!;
    const rN    = document.getElementById('role-next')!;
    imgN.src    = testimonials[next].img;
    imgN.onerror = () => { imgN.src = getAvatar(testimonials[next]); };
    qN.textContent = testimonials[next].quote;
    nN.textContent = testimonials[next].name;
    rN.textContent = testimonials[next].role;

    // Dots
    const dots = document.getElementById('dots-container')!;
    dots.innerHTML = testimonials.map((_, i) =>
      `<button onclick="goTo(${i})" class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full transition-all duration-300 ${i === current ? 'bg-gray-500 w-3 sm:w-4' : 'bg-gray-300'}" aria-label="Ir al testimonio ${i + 1}"></button>`
    ).join('');
  }

  (window as any).goTo = (i: number) => { current = i; updateCarousel(); };

  document.getElementById('prev-testimonial')?.addEventListener('click', () => {
    current = mod(current - 1, testimonials.length);
    updateCarousel();
  });

  document.getElementById('next-testimonial')?.addEventListener('click', () => {
    current = mod(current + 1, testimonials.length);
    updateCarousel();
  });

  // Init
  updateCarousel();
</script>