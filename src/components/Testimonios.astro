<script is:inline>
(function () {
  const carousel = document.getElementById('testimonialsCarousel');
  const dots     = document.querySelectorAll('#testimonialDots .tdot');
  const prev     = document.getElementById('testimonialPrev');
  const next     = document.getElementById('testimonialNext');
  const TOTAL    = 4;
  let current    = 0;

  function setDot(i) {
    dots.forEach(function (d, idx) {
      d.style.width           = idx === i ? '24px' : '8px';
      d.style.background      = idx === i ? '#50C1FC' : 'rgba(255,255,255,0.2)';
    });
  }

  function goTo(i) {
    current = (i + TOTAL) % TOTAL;
    const cards = carousel.querySelectorAll('.snap-start');
    if (cards[current]) {
      const lpad = parseInt(window.getComputedStyle(carousel).paddingLeft) || 0;
      carousel.scrollTo({ left: cards[current].offsetLeft - lpad, behavior: 'smooth' });
    }
    setDot(current);
  }

  // Scroll → actualizar dot
  let st = null;
  carousel.addEventListener('scroll', function () {
    clearTimeout(st);
    st = setTimeout(function () {
      const lpad  = parseInt(window.getComputedStyle(carousel).paddingLeft) || 0;
      const cards = Array.from(carousel.querySelectorAll('.snap-start'));
      let closest = 0, minDist = Infinity;
      cards.forEach(function (c, i) {
        const d = Math.abs(c.offsetLeft - lpad - carousel.scrollLeft);
        if (d < minDist) { minDist = d; closest = i; }
      });
      if (closest !== current) { current = closest; setDot(current); }
    }, 50);
  }, { passive: true });

  prev.addEventListener('click', function () { goTo(current - 1); });
  next.addEventListener('click', function () { goTo(current + 1); });

  // Dots clickeables
  dots.forEach(function (d, i) {
    d.style.cursor = 'pointer';
    d.addEventListener('click', function () { goTo(i); });
  });

  setDot(0);
})();
</script>