  }

  function openPricingPopup() {
    const popup = document.getElementById('pricingPopup');
    if (popup) {
      popup.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        const overlay = popup.querySelector('.popup-overlay');
        const content = popup.querySelector('.popup-content');
        if (overlay) overlay.classList.add('show');
        if (content) content.classList.add('show');
      }, 10);
    }
  }

  function closePricingPopup() {
    const popup = document.getElementById('pricingPopup');
    if (popup) {
      const overlay = popup.querySelector('.popup-overlay');
      const content = popup.querySelector('.popup-content');
      if (overlay) overlay.classList.remove('show');
      if (content) content.classList.remove('show');
      setTimeout(() => {
        popup.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }, 300);
    }
  }

  function openGalleryPopup() {
    const popup = document.getElementById('galleryPopup');
    if (popup) {
      popup.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        const overlay = popup.querySelector('.popup-overlay');
        const content = popup.querySelector('.popup-content');
        if (overlay) overlay.classList.add('show');
        if (content) content.classList.add('show');
      }, 10);
    }
  }

  function closeGalleryPopup() {
    const popup = document.getElementById('galleryPopup');
    if (popup) {
      const overlay = popup.querySelector('.popup-overlay');
      const content = popup.querySelector('.popup-content');
      if (overlay) overlay.classList.remove('show');
      if (content) content.classList.remove('show');
      setTimeout(() => {
        popup.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }, 300);
    }
  }

  function openBenefitsPopup() {
    const popup = document.getElementById('benefitsPopup');
    if (popup) {
      popup.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        const overlay = popup.querySelector('.popup-overlay');
        const content = popup.querySelector('.popup-content');
        if (overlay) overlay.classList.add('show');
        if (content) content.classList.add('show');
      }, 10);
    }
  }

  function closeBenefitsPopup() {
    const popup = document.getElementById('benefitsPopup');
    if (popup) {
      const overlay = popup.querySelector('.popup-overlay');
      const content = popup.querySelector('.popup-content');
      if (overlay) overlay.classList.remove('show');
      if (content) content.classList.remove('show');
      setTimeout(() => {
        popup.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }, 300);
    }
  }

  function openTestimonialsPopup() {
    const popup = document.getElementById('testimonialsPopup');
    if (popup) {
      popup.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        const overlay = popup.querySelector('.popup-overlay');
        const content = popup.querySelector('.popup-content');
        if (overlay) overlay.classList.add('show');
        if (content) content.classList.add('show');
      }, 10);
    }
  }

  function closeTestimonialsPopup() {
    const popup = document.getElementById('testimonialsPopup');
    if (popup) {
      const overlay = popup.querySelector('.popup-overlay');
      const content = popup.querySelector('.popup-content');
      if (overlay) overlay.classList.remove('show');
      if (content) content.classList.remove('show');
      setTimeout(() => {
        popup.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }, 300);
    }
  }

  function openContactPopup() {
    const popup = document.getElementById('contactPopup');
    if (popup) {
      popup.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        const overlay = popup.querySelector('.popup-overlay');
        const content = popup.querySelector('.popup-content');
        if (overlay) overlay.classList.add('show');
        if (content) content.classList.add('show');
      }, 10);
    }
  }

  function closeContactPopup() {
    const popup = document.getElementById('contactPopup');
    if (popup) {
      const overlay = popup.querySelector('.popup-overlay');
      const content = popup.querySelector('.popup-content');
      if (overlay) overlay.classList.remove('show');
      if (content) content.classList.remove('show');
      setTimeout(() => {
        popup.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }, 300);
    }
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeAboutPopup();
      closeServicesPopup();
      closePricingPopup();
      closeGalleryPopup();
      closeBenefitsPopup();
      closeTestimonialsPopup();
      closeContactPopup();
      const menu = document.getElementById('mobileMenu');
      if (menu && !menu.classList.contains('hidden')) {
        toggleMobileMenu();
      }
    }
  });
</script>
