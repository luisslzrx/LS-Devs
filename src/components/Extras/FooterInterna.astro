---
import AcercaDeMi from "../AcercaDeMi.astro";
import Servicios from "../Servicios.astro";
import Precios from "../Precios.astro";
import Portafolio from "../Portafolio.astro";
import Beneficios from "../Beneficios.astro";
import TestimonialsContent from "../Testimonios.astro";
import Contacto from "../Contacto.astro";

//Iconos
import AcercaDeMiIcon from "../icons/AcercaDeMi-Icon.astro";
import BeneficiosIcon from "../icons/Beneficios-Icon.astro";
import TestimoniosIcon from "../icons/Testimoniales-Icon.astro";
import PortafolioIcon from "../icons/Portafolio-Icon.astro";
import PreciosIcon from "../icons/Precios-Icon.astro";
import ContactoIcon from "../icons/Contacto-Icon.astro";
import ServiciosIcon from "../icons/Servicios-Icon.astro";
---

<!-- BOTTOM NAV -->
<footer
  id="mainFooter"
  class="hidden fixed bottom-0 left-1/2 -translate-x-1/2 w-full z-50 transition-all duration-500 ease-[cubic-bezier(.4,0,.2,1)]"
>
  <!-- Botones de navegación -->
  <nav class="max-w-6xl mx-auto px-8 py-8 transition-all duration-500">
    <div class="flex justify-center items-center gap-8">

      <!-- Acerca de mi -->
      <button
        onclick="openAboutPopup()"
        class="group flex flex-col items-center gap-1.5 bg-transparent border-none cursor-pointer"
      >
        <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                     text-white/70 bg-transparent
                     transition-all duration-200
                     group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                     group-active:scale-95">
          <AcercaDeMiIcon class="w-6 h-6" />
        </span>
        <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                     transition-colors duration-200 group-hover:text-white/95">Sobre mí</span>
      </button>

      <!-- Servicios -->
      <button
        onclick="openServicesPopup()"
        class="group flex flex-col items-center gap-1.5 bg-transparent border-none cursor-pointer"
      >
        <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                     text-white/70 bg-transparent
                     transition-all duration-200
                     group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                     group-active:scale-95">
          <ServiciosIcon class="w-6 h-6" />
        </span>
        <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                     transition-colors duration-200 group-hover:text-white/95">Servicios</span>
      </button>

      <!-- Beneficios -->
      <button
        onclick="openBenefitsPopup()"
        class="group flex flex-col items-center gap-1.5 bg-transparent border-none cursor-pointer"
      >
        <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                     text-white/70 bg-transparent
                     transition-all duration-200
                     group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                     group-active:scale-95">
          <BeneficiosIcon class="w-6 h-6" />
        </span>
        <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                     transition-colors duration-200 group-hover:text-white/95">Beneficios</span>
      </button>

      <!-- Portafolio -->
      <button
        onclick="openGalleryPopup()"
        class="group flex flex-col items-center gap-1.5 bg-transparent border-none cursor-pointer"
      >
        <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                     text-white/70 bg-transparent
                     transition-all duration-200
                     group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                     group-active:scale-95">
          <PortafolioIcon class="w-6 h-6" />
        </span>
        <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                     transition-colors duration-200 group-hover:text-white/95">Portafolio</span>
      </button>

      <!-- Precios -->
      <button
        onclick="openPricingPopup()"
        class="group flex flex-col items-center gap-1.5 bg-transparent border-none cursor-pointer"
      >
        <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                     text-white/70 bg-transparent
                     transition-all duration-200
                     group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                     group-active:scale-95">
          <PreciosIcon class="w-6 h-6" />
        </span>
        <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                     transition-colors duration-200 group-hover:text-white/95">Precios</span>
      </button>

      <!-- Testimoniales -->
      <button
        onclick="openTestimonialsPopup()"
        class="group flex flex-col items-center gap-1.5 bg-transparent border-none cursor-pointer"
      >
        <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                     text-white/70 bg-transparent
                     transition-all duration-200
                     group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                     group-active:scale-95">
          <TestimoniosIcon class="w-6 h-6" />
        </span>
        <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                     transition-colors duration-200 group-hover:text-white/95">Testimonios</span>
      </button>

      <!-- Contacto -->
      <button
        onclick="openContactPopup()"
        class="group flex flex-col items-center gap-1.5 bg-transparent border-none cursor-pointer"
      >
        <span class="flex items-center justify-center w-11 h-11 rounded-[0.875rem]
                     text-white/70 bg-transparent
                     transition-all duration-200
                     group-hover:bg-white/10 group-hover:text-white group-hover:scale-110
                     group-active:scale-95">
          <ContactoIcon class="w-6 h-6" />
        </span>
        <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase text-white/50
                     transition-colors duration-200 group-hover:text-white/95">Contacto</span>
      </button>

    </div>
  </nav>
</footer>

<style>
  /* Popup styles */
  .popup-overlay {
    opacity: 0;
    transition: opacity 0.15s ease-out;
  }
  .popup-overlay.show { opacity: 1; }

  .popup-content {
    transform: scale(0.9) translateY(20px);
    opacity: 0;
    transition: all 0.2s ease-out;
  }
  .popup-content.show {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
</style>

<script is:inline>
  const footer = document.getElementById("mainFooter");

  /* scroll animation solo desktop */

  window.addEventListener("scroll", () => {

    if (window.innerWidth >= 768) {

      if (window.scrollY > 60) {
        footer.classList.add("scrolled");
      } else {
        footer.classList.remove("scrolled");
      }

    }

  });
</script>

<!-- Popup About -->
<div id="aboutPopup" class="fixed inset-0 z-[60] hidden">
  <!-- Overlay -->
  <div 
    class="popup-overlay absolute inset-0 bg-black/60 backdrop-blur-sm"
    onclick="closeAboutPopup()"
  ></div>
  
  <!-- Contenedor del contenido -->
  <div class="relative flex items-center justify-center min-h-screen p-4 overflow-visible">
    <div class="popup-content">
      <AcercaDeMi />
    </div>
  </div>
</div>

<!-- Popup Services -->
<div id="servicesPopup" class="fixed inset-0 z-[60] hidden">
  <!-- Overlay -->
  <div 
    class="popup-overlay absolute inset-0 bg-black/60 backdrop-blur-sm"
