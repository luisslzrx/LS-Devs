      setTimeout(() => {
        popup.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }, 200);
    }
  }

  // Cerrar con tecla Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeAboutPopup();
      closeServicesPopup();
      closePricingPopup();
      closeGalleryPopup();
      closeBenefitsPopup();
      closeTestimonialsPopup();
      closeContactPopup();
    }
  });
</script>
