---
---

<header
  id="mainHeader"
  class="fixed top-0 left-1/2 -translate-x-1/2 w-full z-50 transition-all duration-500 ease-[cubic-bezier(.4,0,.2,1)]"
>

<!-- DESKTOP HEADER -->
<nav class="hidden md:block max-w-6xl mx-auto px-8 py-12 transition-all duration-500">
  
  <div class="flex justify-center items-center gap-12 h-full">

    <a href="/" class="text-white font-semibold hover:text-white/80 transition-colors">
      Inicio
    </a>

    <a href="/proyectos" class="text-white font-semibold hover:text-white/80 transition-colors">
      Proyectos
    </a>

    <a href="/blog" class="text-white font-semibold hover:text-white/80 transition-colors">
      Blog
    </a>

    <a href="/#contacto" class="text-white font-semibold hover:text-white/80 transition-colors">
      Contacto
    </a>

  </div>

</nav>

</header>

<style>

/* SCROLL EFFECT SOLO DESKTOP */

@media (min-width:768px){

#mainHeader.scrolled{

  width:auto;

  top:18px;

  border-radius:9999px;

  padding-left:32px;
  padding-right:32px;


  background: rgba(255, 255, 255, 0.08);
  background-color: rgba(255, 255, 255, 0.03);

  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(18px);

  box-shadow:
    0 8px 30px rgba(0, 0, 0, 0.35),
    inset 0 1px 0 rgba(255, 255, 255, 0.15);

}

#mainHeader.scrolled nav{
  padding-top:16px;
  padding-bottom:16px;
}

#mainHeader.scrolled nav div{
  gap:32px;
  font-size:0.9rem;
}

}

</style>

<script is:inline>
  const header = document.getElementById("mainHeader");

  /* scroll animation solo desktop */

  window.addEventListener("scroll", () => {

    if (window.innerWidth >= 768) {

      if (window.scrollY > 60) {
        header.classList.add("scrolled");
      } else {
        header.classList.remove("scrolled");
      }

    }

  });
</script>
