<!-- CONTACTO -->
<section id="contacto">
  <div class="max-w-6xl mx-auto py-16 lg:py-24">
    <!-- Contenedor glass principal -->
    <div
      class="glass-container grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-8 lg:gap-12 items-end p-8 lg:p-16 rounded-3xl"
    >
      <!-- ── Columna izquierda ── -->
      <div>
        <!-- Tag -->
        <div
          class="inline-flex items-center gap-2 text-xs font-bold tracking-wider uppercase text-blue-400 mb-4 lg:mb-6 px-4 py-2 rounded-full"
          style="background: rgba(79,163,255,0.10); border: 1px solid rgba(79,163,255,0.22);"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 shrink-0"></span>
          Contacto
        </div>

        <h2
          class="text-3xl lg:text-4xl font-extrabold tracking-tight leading-tight text-blue-50 mb-4 lg:mb-4"
        >
          ¿Listo para<br />
          <span class="text-gradient"> empezar? </span>
        </h2>

        <p
          class="text-sm lg:text-base text-white/75 leading-relaxed mb-6 lg:mb-8"
        >
          Cuéntame tu proyecto y en menos de 24 horas recibirás una propuesta
          personalizada sin costo ni compromiso.
        </p>

        <!-- Info de contacto -->
        <div class="flex flex-col gap-3 lg:gap-4">
          <!-- Email -->
          <div
            class="flex items-center gap-3 lg:gap-4 px-4 lg:px-5 py-3 lg:py-4 rounded-2xl"
            style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);"
          >
            <span
              class="shrink-0 w-4 h-4 lg:w-5 lg:h-5 flex items-center justify-center"
            >
              <svg
                class="w-3 h-3 lg:w-4 lg:h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#4fa3ff"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </span>
            <div>
              <strong
                class="block text-xs lg:text-sm text-blue-50 font-bold mb-0.5"
                >Email</strong
              >
              <span class="text-xs lg:text-sm text-blue-300/50"
                >luisgerdx521@gmail.com</span
              >
            </div>
          </div>

          <!-- WhatsApp -->
          <div
            class="flex items-center gap-3 lg:gap-4 px-4 lg:px-5 py-3 lg:py-4 rounded-2xl"
            style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);"
          >
            <span
              class="shrink-0 w-4 h-4 lg:w-5 lg:h-5 flex items-center justify-center"
            >
              <svg
                class="w-3 h-3 lg:w-4 lg:h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#4fa3ff"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 1 2.11-.45c.91.34 1.85.57 2.81A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
            </span>
            <div>
              <strong
                class="block text-xs lg:text-sm text-blue-50 font-bold mb-0.5"
                >WhatsApp</strong
              >
              <span class="text-xs lg:text-sm text-blue-300/50"
                >+52 228 853 5112</span
              >
            </div>
          </div>

          <!-- Tiempo de respuesta -->
          <div
            class="flex items-center gap-3 lg:gap-4 px-4 lg:px-5 py-3 lg:py-4 rounded-2xl"
            style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);"
          >
            <span
              class="shrink-0 w-4 h-4 lg:w-5 lg:h-5 flex items-center justify-center"
            >
              <svg
                class="w-3 h-3 lg:w-4 lg:h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#4fa3ff"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </span>
            <div>
              <strong
                class="block text-xs lg:text-sm text-blue-50 font-bold mb-0.5"
                >Respuesta en</strong
              >
              <span class="text-xs lg:text-sm text-blue-300/50"
                >Menos de 24 horas hábiles</span
              >
            </div>
          </div>
        </div>
      </div>

      <!-- ── Columna derecha — formulario ── -->
      <form id="contact-form" class="flex flex-col gap-3 lg:gap-4">
        <!-- Fila: Nombre + Email -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-4">
          <div class="flex flex-col gap-2">
            <label
              class="text-xs font-bold tracking-wider uppercase text-blue-300/50"
            >
              Nombre
            </label>
            <input
              type="text"
              name="user_name"
              placeholder="Tu nombre completo"
              required
              class="glass-input h-10 lg:h-12 px-4 lg:px-5 rounded-2xl text-xs lg:text-sm text-blue-50 font-sans transition-all duration-200"
              style="background: rgba(255,255,255,0.07); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.12); box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label
              class="text-xs font-bold tracking-wider uppercase text-blue-300/50"
            >
              Email
            </label>
            <input
              type="email"
              name="user_email"
              placeholder="tu@correo.com"
              required
              class="glass-input h-10 lg:h-12 px-4 lg:px-5 rounded-2xl text-xs lg:text-sm text-blue-50 font-sans transition-all duration-200"
              style="background: rgba(255,255,255,0.07); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.12); box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);"
            />
          </div>
        </div>

        <!-- Tipo de proyecto -->
        <div class="flex flex-col gap-2">
          <label
            class="text-xs font-bold tracking-wider uppercase text-blue-300/50"
          >
            Tipo de proyecto
          </label>
          <select
            name="project_type"
            class="glass-input glass-select h-10 lg:h-12 px-4 lg:px-5 rounded-2xl text-xs lg:text-sm text-blue-300/50 font-sans cursor-pointer appearance-none transition-all duration-200"
            style="background: rgba(255,255,255,0.07); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.12); box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);"
          >
            <option>Selecciona un servicio...</option>
            <option>Landing Page</option>
            <option>Sitio Web Informativo</option>
            <option>Tienda en Línea</option>
            <option>Mantenimiento Web</option>
          </select>
        </div>

        <!-- Fila: Presupuesto + Teléfono -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-4">
          <div class="flex flex-col gap-2">
            <label
              class="text-xs font-bold tracking-wider uppercase text-blue-300/50"
            >
              Presupuesto
            </label>
            <select
              name="budget"
              class="glass-input glass-select h-10 lg:h-12 px-4 lg:px-5 rounded-2xl text-xs lg:text-sm text-blue-300/50 font-sans cursor-pointer appearance-none transition-all duration-200"
              style="background: rgba(255,255,255,0.07); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.12); box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);"
            >
              <option>Rango aproximado...</option>
              <option>$5,000 – $15,000 MXN</option>
              <option>$15,000 – $35,000 MXN</option>
              <option>$35,000 MXN+</option>
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <label
              class="text-xs font-bold tracking-wider uppercase text-blue-300/50"
            >
              Teléfono (opcional)
            </label>
            <input
              type="tel"
              name="phone"
              placeholder="+52 55 0000 0000"
              class="glass-input h-10 lg:h-12 px-4 lg:px-5 rounded-2xl text-xs lg:text-sm text-blue-50 font-sans transition-all duration-200"
              style="background: rgba(255,255,255,0.07); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.12); box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);"
            />
          </div>
        </div>

        <!-- Mensaje -->
        <div class="flex flex-col gap-2">
          <label
            class="text-xs font-bold tracking-wider uppercase text-blue-300/50"
          >
            Cuéntame de tu proyecto
          </label>
          <textarea
            name="message"
            required
            placeholder="¿Qué necesitas? ¿Tienes referencias? ¿Cuándo lo necesitas?"
            rows="4"
            class="glass-input px-4 lg:px-5 py-3 lg:py-4 rounded-2xl text-xs lg:text-sm text-blue-50 font-sans resize-none transition-all duration-200"
            style="background: rgba(255,255,255,0.07); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.12); box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);"
          ></textarea>
        </div>

        <!-- Botón -->
        <button
          type="submit"
          class="btn-glass-highlight relative overflow-hidden w-full h-12 lg:h-14 flex items-center justify-center gap-2 font-bold text-sm lg:text-base text-white rounded-full cursor-pointer mt-1 transition-all duration-200 hover:-translate-y-0.5"
          style="background: linear-gradient(135deg, rgba(45,133,240,0.88), rgba(18,86,199,0.92)); backdrop-filter: blur(20px); border: 1px solid rgba(79,163,255,0.40); box-shadow: inset 0 1px 0 rgba(255,255,255,0.20);"
        >
          Solicitar cotización gratis
        </button>
      </form>

      <p id="form-status" class="text-sm mt-2 text-blue-300"></p>
    </div>
  </div>
</section>

<script
  is:inline
  src="https://cdn.jsdelivr.net/npm/emailjs-com@3/dist/email.min.js"></script>

<script is:inline>
  emailjs.init("XbOAQpdJXH3tJep6i");

  const form = document.getElementById("contact-form");
  const status = document.getElementById("form-status");
  const button = form.querySelector("button");

  form.addEventListener("submit", function (e) {
    e.preventDefault();

    button.disabled = true;
    button.innerText = "Enviando...";

    emailjs
      .sendForm("service_mpy53hk", "template_9jrfyls", this)
      .then(() => {
        status.innerHTML =
          "<span style='color:#4CAF50'>✔ Mensaje enviado correctamente</span>";
        form.reset();
      })
      .catch((error) => {
        status.innerHTML = "<span style='color:#ff6b6b'>Error al enviar</span>";
        console.error("ERROR EMAILJS:", error);
      })
      .finally(() => {
        button.disabled = false;
        button.innerText = "Solicitar cotización gratis";
      });
  });
</script>
