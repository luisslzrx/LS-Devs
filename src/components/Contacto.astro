        <script>
          const form = document.getElementById(
            "contacto-form",
          ) as HTMLFormElement;
          const statusDiv = document.getElementById("form-status");

          if (form && statusDiv) {
            form.addEventListener("submit", async (e) => {
              e.preventDefault();

              const button = form.querySelector(
                'button[type="submit"]',
              ) as HTMLButtonElement;
              if (!button) return;

              const originalText = button.innerHTML;
              const originalClasses = button.className;

              // Actualizar estado del botón a "Enviando..."
              button.disabled = true;
              button.textContent = "Enviando...";
              button.className =
                "w-full px-6 py-3 bg-[#50C1FC]/50 text-[#0d0d0d]/60 font-semibold rounded-xl cursor-not-allowed transition-all duration-200";

              // Limpiar y ocultar estado anterior
              statusDiv.classList.add("hidden");
              statusDiv.innerHTML = "";

              const formData = new FormData(form);
              let actionUrl = form.action;

              // Si es FormSubmit, redirigir a su endpoint AJAX
              if (
                actionUrl.includes("formsubmit.co") &&
                !actionUrl.includes("/ajax/")
              ) {
                actionUrl = actionUrl.replace(
                  "formsubmit.co/",
                  "formsubmit.co/ajax/",
                );
              }

              try {
                const response = await fetch(actionUrl, {
                  method: form.method,
                  body: formData,
                  headers: {
                    Accept: "application/json",
                  },
                });

                if (response.ok) {
                  // Éxito
                  statusDiv.innerHTML = `
            <div class="flex items-center gap-3 p-4 rounded-xl text-[#4ade80] transition-all duration-500 ease-out opacity-0 translate-y-2" 
                 style="background: rgba(74, 222, 128, 0.08); border: 1px solid rgba(74, 222, 128, 0.2);" id="status-message">
              <svg class="w-5 h-5 flex-shrink-0 text-[#4ade80]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-sm font-medium">¡Mensaje enviado con éxito! Nos pondremos en contacto pronto.</span>
            </div>
          `;
                  statusDiv.classList.remove("hidden");

                  // Disparar la animación de entrada
                  requestAnimationFrame(() => {
                    const messageEl = document.getElementById("status-message");
                    if (messageEl) {
                      requestAnimationFrame(() => {
                        messageEl.classList.remove(
                          "opacity-0",
                          "translate-y-2",
                        );
                        messageEl.classList.add("opacity-100", "translate-y-0");
                      });
                    }
                  });

                  form.reset();
                } else {
                  throw new Error();
                }
              } catch (error) {
                // Error
                statusDiv.innerHTML = `
          <div class="flex items-center gap-3 p-4 rounded-xl text-[#f87171] transition-all duration-500 ease-out opacity-0 translate-y-2" 
               style="background: rgba(248, 113, 113, 0.08); border: 1px solid rgba(248, 113, 113, 0.2);" id="status-message">
            <svg class="w-5 h-5 flex-shrink-0 text-[#f87171]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span class="text-sm font-medium">Hubo un error al enviar el mensaje. Por favor, inténtalo de nuevo.</span>
          </div>
        `;
                statusDiv.classList.remove("hidden");

                // Disparar la animación de entrada
                requestAnimationFrame(() => {
                  const messageEl = document.getElementById("status-message");
                  if (messageEl) {
                    requestAnimationFrame(() => {
                      messageEl.classList.remove("opacity-0", "translate-y-2");
                      messageEl.classList.add("opacity-100", "translate-y-0");
                    });
                  }
                });
              } finally {
                // Restaurar estado del botón
                button.disabled = false;
                button.innerHTML = originalText;
                button.className = originalClasses;
              }
            });
          }
        </script>
      </div>
    </div>
  </div>
</section>
