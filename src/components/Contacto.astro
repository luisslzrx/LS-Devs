---
// Contact2.astro
// Componente de contacto para popup — mismo estilo visual
---

<div class="relative bg-white rounded-3xl w-full max-w-5xl mx-auto flex flex-col justify-center min-h-[85vh]">


  <!-- Botón cerrar -->
  <button
    onclick="closeContactPopup()"
    class="absolute top-4 right-4 z-20 w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-gray-900 text-white
           flex items-center justify-center hover:bg-gray-700 transition-colors duration-200 cursor-pointer"
    aria-label="Cerrar contacto"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
    </svg>
  </button>

  <!-- Layout: info izquierda + formulario derecha -->
  <div class="flex flex-col md:flex-row gap-0 pt-8 sm:pt-10">

    <!-- Columna izquierda -->
    <div class="w-full md:w-[42%] flex-shrink-0 px-4 sm:px-8 pb-6 sm:pb-10 flex flex-col gap-4 sm:gap-6">

      <div>
        <h2 class="text-lg sm:text-xl md:text-2xl font-bold text-gray-900 mb-2">¿Listo para empezar?</h2>
        <p class="text-gray-400 text-xs sm:text-sm leading-relaxed">
          Cuéntame tu proyecto y en menos de 24 horas recibirás una propuesta personalizada sin costo ni compromiso.
        </p>
      </div>

      <div class="flex flex-col gap-0 divide-y divide-gray-100">

        <!-- Email -->
        <div class="flex items-center gap-3 sm:gap-4 py-3 sm:py-5">
          <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full border border-gray-200 bg-gray-100 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-[#111828]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
          </div>
          <div>
            <p class="text-[10px] sm:text-xs font-semibold text-gray-400 uppercase tracking-widest mb-0.5">Email</p>
            <a href="mailto:luisgerdx521@gmail.com" class="text-gray-800 text-xs sm:text-sm font-medium hover:text-[#111828] transition-colors">
              luisgerdx521@gmail.com
            </a>
          </div>
        </div>

        <!-- WhatsApp -->
        <div class="flex items-center gap-3 sm:gap-4 py-3 sm:py-5">
          <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full border border-gray-200 bg-gray-100 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-[#111828]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
            </svg>
          </div>
          <div>
            <p class="text-[10px] sm:text-xs font-semibold text-gray-400 uppercase tracking-widest mb-0.5">WhatsApp</p>
            <a href="https://wa.me/522288535112" target="_blank" class="text-gray-800 text-xs sm:text-sm font-medium hover:text-[#111828] transition-colors">
              +52 228 853 5112
            </a>
          </div>
        </div>

        <!-- Tiempo de respuesta -->
        <div class="flex items-center gap-3 sm:gap-4 py-3 sm:py-5">
          <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full border border-gray-200 bg-gray-100 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-[#111828]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
            </svg>
          </div>
          <div>
            <p class="text-[10px] sm:text-xs font-semibold text-gray-400 uppercase tracking-widest mb-0.5">Respuesta en</p>
            <p class="text-gray-800 text-xs sm:text-sm font-medium">Menos de 24 horas hábiles</p>
          </div>
        </div>

      </div>
    </div>

    <!-- Divisor vertical -->
    <div class="hidden md:block w-px bg-gray-100 my-8"></div>

    <!-- Columna derecha: formulario -->
    <div class="flex-1 px-4 sm:px-8 pb-6 sm:pb-10 pt-2">
      <h3 class="text-base sm:text-lg md:text-xl font-bold text-gray-900 mb-4 sm:mb-5">Solicitar cotización gratis</h3>

      <form id="contact-form" class="flex flex-col gap-2 sm:gap-3">

        <!-- Nombre + Email -->
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-3">
          <input
            type="text"
            name="user_name"
            placeholder="Nombre"
            required
            class="flex-1 px-3 sm:px-4 py-2 sm:py-3 bg-gray-50 border border-gray-200 rounded-xl text-xs sm:text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:border-[#111828] focus:bg-white transition-all"
          />
          <input
            type="email"
            name="user_email"
            placeholder="Email"
            required
            class="flex-1 px-3 sm:px-4 py-2 sm:py-3 bg-gray-50 border border-gray-200 rounded-xl text-xs sm:text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:border-[#111828] focus:bg-white transition-all"
          />
        </div>

        <!-- Tipo de proyecto -->
        <div class="relative">
          <select
            name="project_type"
            class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-gray-50 border border-gray-200 rounded-xl text-xs sm:text-sm text-gray-500 focus:outline-none focus:border-[#111828] focus:bg-white transition-all appearance-none cursor-pointer pr-10"
          >
            <option value="" disabled selected>Tipo de proyecto</option>
            <option value="landing">Landing Page</option>
            <option value="sitio">Sitio Web Informativo</option>
            <option value="ecommerce">Tienda en Línea</option>
            <option value="mantenimiento">Mantenimiento Web</option>
          </select>
          <div class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"/>
            </svg>
          </div>
        </div>

        <!-- Presupuesto -->
        <div class="relative">
          <select
            name="budget"
            class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-gray-50 border border-gray-200 rounded-xl text-xs sm:text-sm text-gray-500 focus:outline-none focus:border-[#111828] focus:bg-white transition-all appearance-none cursor-pointer pr-10"
          >
            <option value="" disabled selected>Presupuesto aproximado</option>
            <option value="3-5">$3,000 – $5,000 MXN</option>
            <option value="5-7.5">$5,000 – $7,500 MXN</option>
            <option value="5-7.5">$7,500 – $15,500 MXN</option>
            <option value="5-7.5">$15,500 – 20,500 MXN</option>
            <option value="5-7.5">$20,500 – 35,500 MXN</option>
            <option value="7.5+">$35,500 MXN+</option>
          </select>
          <div class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"/>
            </svg>
          </div>
        </div>

        <!-- Teléfono -->
        <input
          type="tel"
          name="phone"
          placeholder="Teléfono (opcional)"
          class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-gray-50 border border-gray-200 rounded-xl text-xs sm:text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:border-[#111828] focus:bg-white transition-all"
        />

        <!-- Mensaje -->
        <textarea
          name="message"
          placeholder="Cuéntame sobre tu proyecto..."
          rows="3 sm:4"
          required
          class="w-full px-3 sm:px-4 py-2 sm:py-3 bg-gray-50 border border-gray-200 rounded-xl text-xs sm:text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:border-[#111828] focus:bg-white transition-all resize-none"
        ></textarea>

        <!-- Botón enviar -->
        <button
          type="submit"
          class="w-full px-4 sm:px-6 py-2 sm:py-3 bg-[#111828] text-white text-xs sm:text-sm font-semibold rounded-xl hover:bg-[#1f2937] transition-colors duration-200 cursor-pointer"
        >
          Enviar solicitud
        </button>

      </form>
      <p id="form-status" class="text-sm mt-2 text-[#111828]"></p>
    </div>

  </div>

</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/emailjs-com@3/dist/email.min.js"></script>

<script is:inline>
  emailjs.init("XbOAQpdJXH3tJep6i");

  const form = document.getElementById("contact-form");
  const status = document.getElementById("form-status");
  const button = form.querySelector("button");

  form.addEventListener("submit", function (e) {
    e.preventDefault();
    button.disabled = true;
    button.innerText = "Enviando...";

    emailjs
      .sendForm("service_mpy53hk", "template_9jrfyls", this)
      .then(() => {
        status.innerHTML = "<span style='color:#111828'>✔ Mensaje enviado correctamente</span>";
        form.reset();
      })
      .catch((error) => {
        status.innerHTML = "<span style='color:#ef4444'>Error al enviar. Intenta de nuevo.</span>";
        console.error("ERROR EMAILJS:", error);
      })
      .finally(() => {
        button.disabled = false;
        button.innerText = "Solicitar cotización gratis →";
      });
  });
</script>