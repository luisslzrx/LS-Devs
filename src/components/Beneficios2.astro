---
// Benefits2.astro
// Componente de beneficios — mismo estilo visual que Services
---

<style>
  .metric-bar {
    height: 6px;
    border-radius: 999px;
    background: #e0f2fe;
    overflow: hidden;
  }
  .metric-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #38bdf8, #0ea5e9);
    width: 0%;
    transition: width 1s ease;
  }
</style>

<div class="relative bg-white rounded-3xl w-full max-w-5xl mx-auto">

  <!-- Badge -->
  <div class="absolute -top-4 left-6 z-20">
    <span class="bg-sky-400 text-white text-sm sm:text-xl font-bold px-4 sm:px-6 py-2 rounded-xl shadow-lg inline-block">
      Beneficios
    </span>
  </div>

  <!-- Botón cerrar -->
  <button
    onclick="closeBenefitsPopup()"
    class="absolute top-4 right-4 z-20 w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-gray-900 text-white
           flex items-center justify-center hover:bg-gray-700 transition-colors duration-200 cursor-pointer"
    aria-label="Cerrar beneficios"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
    </svg>
  </button>

  <div class="pt-10 sm:pt-12 px-4 sm:px-10 pb-6 sm:pb-10">

    <!-- Header -->
    <div class="text-center mb-6 sm:mb-8">
      <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-gray-900 mb-2">Lo que me diferencia</h2>
    </div>

    <!-- Grid superior: 4 beneficios -->
    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-6 sm:mb-8">

      <!-- Entrega rápida -->
      <div class="bg-gray-50 rounded-2xl p-4 sm:p-6 flex flex-col items-center text-center gap-2 sm:gap-3">
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-sky-50 border border-sky-100 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6 sm:h-6 text-sky-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
          </svg>
        </div>
        <h3 class="text-xs sm:text-sm font-bold text-gray-900">Entrega ultra rápida</h3>
        <p class="text-gray-400 text-[10px] sm:text-xs leading-relaxed">Landing pages en 3–5 días. Sitios completos en 7–14 días. Sin esperas interminables.</p>
      </div>

      <!-- Conversión -->
      <div class="bg-gray-50 rounded-2xl p-4 sm:p-6 flex flex-col items-center text-center gap-2 sm:gap-3">
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-sky-50 border border-sky-100 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6 sm:h-6 text-sky-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
          </svg>
        </div>
        <h3 class="text-xs sm:text-sm font-bold text-gray-900">Orientado a conversión</h3>
        <p class="text-gray-400 text-[10px] sm:text-xs leading-relaxed">Cada elemento tiene un propósito: llevar al visitante a tomar acción. Diseño con estrategia.</p>
      </div>

      <!-- Presupuesto -->
      <div class="bg-gray-50 rounded-2xl p-4 sm:p-6 flex flex-col items-center text-center gap-2 sm:gap-3">
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-sky-50 border border-sky-100 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6 sm:h-6 text-sky-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
          </svg>
        </div>
        <h3 class="text-xs sm:text-sm font-bold text-gray-900">Flexible a tu presupuesto</h3>
        <p class="text-gray-400 text-[10px] sm:text-xs leading-relaxed">Planes adaptados para negocios en crecimiento. Calidad de agencia sin sus precios.</p>
      </div>

      <!-- SEO + Responsive -->
      <div class="bg-gray-50 rounded-2xl p-4 sm:p-6 flex flex-col items-center text-center gap-2 sm:gap-3">
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-sky-50 border border-sky-100 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-6 sm:h-6 text-sky-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3"/>
          </svg>
        </div>
        <h3 class="text-xs sm:text-sm font-bold text-gray-900">Responsive + SEO desde el día 1</h3>
        <p class="text-gray-400 text-[10px] sm:text-xs leading-relaxed">Tu sitio se ve perfecto en cualquier dispositivo y aparece en Google desde el lanzamiento.</p>
      </div>

    </div>

    <!-- Grid inferior: métricas + stats + testimonio -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 sm:gap-4">

      <!-- Métricas de calidad -->
      <div class="bg-gray-50 rounded-2xl p-4 sm:p-6">
        <h3 class="text-xs sm:text-sm font-bold text-gray-900 mb-3 sm:mb-5">Métricas de calidad</h3>
        <div class="flex flex-col gap-4" id="metrics-container">

          <div>
            <div class="flex justify-between mb-1 sm:mb-1.5">
              <span class="text-[10px] sm:text-xs font-semibold text-gray-600">Velocidad</span>
              <span class="text-[10px] sm:text-xs font-bold text-sky-500">95</span>
            </div>
            <div class="metric-bar"><div class="metric-fill" data-value="95"></div></div>
          </div>

          <div>
            <div class="flex justify-between mb-1 sm:mb-1.5">
              <span class="text-[10px] sm:text-xs font-semibold text-gray-600">SEO</span>
              <span class="text-[10px] sm:text-xs font-bold text-sky-500">92</span>
            </div>
            <div class="metric-bar"><div class="metric-fill" data-value="92"></div></div>
          </div>

          <div>
            <div class="flex justify-between mb-1 sm:mb-1.5">
              <span class="text-[10px] sm:text-xs font-semibold text-gray-600">Accesibilidad</span>
              <span class="text-[10px] sm:text-xs font-bold text-sky-500">90</span>
            </div>
            <div class="metric-bar"><div class="metric-fill" data-value="90"></div></div>
          </div>

          <div>
            <div class="flex justify-between mb-1 sm:mb-1.5">
              <span class="text-[10px] sm:text-xs font-semibold text-gray-600">Conversión</span>
              <span class="text-[10px] sm:text-xs font-bold text-sky-500">87</span>
            </div>
            <div class="metric-bar"><div class="metric-fill" data-value="87"></div></div>
          </div>

        </div>
      </div>

      <!-- Stats + Testimonio -->
      <div class="flex flex-col gap-3 sm:gap-4">

        <!-- Stats: rating + clientes -->
        <div class="grid grid-cols-2 gap-3 sm:gap-4">
          <div class="bg-sky-400 rounded-2xl p-3 sm:p-5 flex flex-col items-center justify-center text-center">
            <p class="text-2xl sm:text-4xl font-black text-white leading-none">4.9</p>
            <div class="flex gap-0.5 mt-1 sm:mt-1.5 mb-1">
              {[1,2,3,4,5].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-2 h-2 sm:w-3 sm:h-3 text-white" viewBox="0 0 24 24" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd"/>
                </svg>
              ))}
            </div>
            <p class="text-white/80 text-[8px] sm:text-[10px] font-semibold tracking-wide uppercase">Calificación promedio</p>
          </div>

          <div class="bg-gray-50 rounded-2xl p-3 sm:p-5 flex flex-col items-center justify-center text-center">
            <p class="text-2xl sm:text-4xl font-black text-gray-900 leading-none">+20</p>
            <p class="text-gray-400 text-[8px] sm:text-[10px] font-semibold tracking-wide uppercase mt-1 sm:mt-2">Clientes atendidos</p>
          </div>
        </div>

        <!-- Testimonio -->
        <div class="bg-gray-50 rounded-2xl p-3 sm:p-5 flex flex-col gap-2 sm:gap-3 flex-1">
          <!-- Comillas decorativas -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 sm:w-7 sm:h-7 text-sky-200" viewBox="0 0 24 24" fill="currentColor">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179Zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179Z"/>
          </svg>
          <p class="text-gray-600 text-[10px] sm:text-xs leading-relaxed italic flex-1">
            "El sitio superó mis expectativas. En el primer mes triplicamos los contactos de nuevos clientes."
          </p>
          <div class="flex items-center gap-2 sm:gap-3 border-t border-gray-100 pt-2 sm:pt-3">
            <div class="w-6 h-6 sm:w-8 sm:h-8 rounded-full bg-sky-100 flex items-center justify-center flex-shrink-0">
              <span class="text-sky-500 text-[10px] sm:text-xs font-bold">ML</span>
            </div>
            <div>
              <p class="text-[10px] sm:text-xs font-bold text-gray-800">María López</p>
              <p class="text-[8px] sm:text-[10px] text-gray-400">CEO · ConsulBiz Pro</p>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>

</div>

<script>
  // Animar las barras cuando el componente es visible
  function animateBars() {
    document.querySelectorAll('.metric-fill').forEach((bar) => {
      const el = bar as HTMLElement;
      const value = el.dataset.value || '0';
      setTimeout(() => {
        el.style.width = value + '%';
      }, 200);
    });
  }

  // Observar cuando el componente entra al viewport
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateBars();
        observer.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const container = document.getElementById('metrics-container');
  if (container) observer.observe(container);

  // También animar si ya está visible al cargar
  animateBars();
</script>