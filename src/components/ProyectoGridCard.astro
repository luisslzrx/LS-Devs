---
const { title, image, link, tags = [], description, date } = Astro.props;
---

<a href={link || '#'} class="block w-full min-h-[320px] bg-[#1d1d1f] rounded-2xl overflow-hidden flex flex-col relative hover:scale-[1.02] transition-all duration-300 hover:shadow-xl">
  <!-- Image top -->
  <div class="relative h-48 w-full">
    <img
      src={image}
      alt={title}
      class="absolute inset-0 w-full h-full object-cover"
    />
  </div>
  <!-- Text bottom -->
  <div class="p-5 pt-4">
    <p class="text-xs text-[#a1a1a6] mb-1">{tags[0] || 'Proyecto'}</p>
    <h3 class="text-lg font-bold text-white leading-snug">
      {title}
    </h3>
  </div>
</a>
