---
// Proyectos2.astro
// Portafolio con estilo consistente a otros popups
import { getCollection } from "astro:content";

const proyectos = await getCollection("proyectos");
proyectos.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const proyectosLimitados = proyectos.slice(0, 6);

const [p0, p1, p2, p3, p4, p5] = proyectosLimitados;
---

<div class="relative bg-white rounded-3xl w-full max-w-5xl mx-auto">

  <!-- Badge "Portafolio" -->
  <div class="absolute -top-4 left-6 z-20">
    <span class="bg-sky-400 text-white text-sm sm:text-xl font-bold px-4 sm:px-6 py-2 rounded-xl shadow-lg inline-block">
      Portafolio
    </span>
  </div>

  <!-- Botón cerrar -->
  <button
    onclick="closeGalleryPopup()"
    class="absolute top-4 right-4 z-20 w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-gray-900 text-white
           flex items-center justify-center hover:bg-gray-700 transition-colors duration-200 cursor-pointer"
    aria-label="Cerrar portafolio"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
    </svg>
  </button>

  <!-- Contenido -->
  <div class="pt-10 sm:pt-12 px-4 sm:px-10 pb-6 sm:pb-10">

    <!-- Header -->
    <div class="text-center mb-6 sm:mb-10">
      <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-gray-900 mb-2 sm:mb-3">Proyectos que hablan por sí solos</h2>
      <p class="text-gray-400 text-xs sm:text-sm leading-relaxed max-w-xl mx-auto">
        Una selección de trabajos recientes donde diseño, funcionalidad y<br/>
        conversión trabajan juntos.
      </p>
    </div>

    <!-- Grid de proyectos: 1 columna móvil, 2 tablet, 3 desktop -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-0">

      {/* Primera fila: 3 proyectos */}
      {[p0, p1, p2].map(
        (proyecto) =>
          proyecto && (
            <a
              href={proyecto.data.link ?? "#"}
              target="_blank"
              rel="noopener noreferrer"
              class="relative overflow-hidden cursor-pointer border-r border-b border-gray-200 group rounded-lg block"
            >
              {/* Imagen */}
              <div class="relative w-full" style="aspect-ratio: 16/9;">
                <img
                  src={proyecto.data.image}
                  alt={proyecto.data.title}
                  class="w-full h-full object-cover object-center transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
                
                {/* Overlay hover */}
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-3 sm:p-6">
                  <div class="text-center text-white">
                    <h3 class="text-sm sm:text-lg font-bold mb-1 sm:mb-2">{proyecto.data.title}</h3>
                    <p class="text-[10px] sm:text-sm leading-relaxed">{proyecto.data.description}</p>
                  </div>
                </div>
              </div>
            </a>
          ),
      )}

      {/* Segunda fila: 3 proyectos */}
      {[p3, p4, p5].map(
        (proyecto) =>
          proyecto && (
            <a
              href={proyecto.data.link ?? "#"}
              target="_blank"
              rel="noopener noreferrer"
              class="relative overflow-hidden cursor-pointer border-r border-gray-200 group rounded-lg block"
            >
              {/* Imagen */}
              <div class="relative w-full" style="aspect-ratio: 16/9;">
                <img
                  src={proyecto.data.image}
                  alt={proyecto.data.title}
                  class="w-full h-full object-cover object-center transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                  onerror="this.style.display='none'"
                />
                
                {/* Overlay hover */}
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-3 sm:p-6">
                  <div class="text-center text-white">
                    <h3 class="text-sm sm:text-lg font-bold mb-1 sm:mb-2">{proyecto.data.title}</h3>
                    <p class="text-[10px] sm:text-sm leading-relaxed">{proyecto.data.description}</p>
                  </div>
                </div>
              </div>
            </a>
          ),
      )}

    </div>

    <!-- CTA final -->
    <div class="text-center mt-6 sm:mt-10">
      <a
        href="/proyectos"
        class="inline-flex items-center gap-2 bg-gray-900 hover:bg-gray-800 text-white font-bold text-xs sm:text-sm px-4 sm:px-8 py-2 sm:py-4 rounded-full transition-colors duration-200"
      >
        Ver todos los proyectos
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
        </svg>
      </a>
    </div>

  </div>

</div>
