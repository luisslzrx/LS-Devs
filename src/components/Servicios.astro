<script is:inline>
(function () {
  const carousel = document.getElementById('servicesCarousel');
  const dotsContainer = document.getElementById('servicesDots');
  const prev     = document.getElementById('servicesPrev');
  const next     = document.getElementById('servicesNext');
  let current    = 0;

  function getValidCards() {
    const lpad = parseInt(window.getComputedStyle(carousel).paddingLeft) || 0;
    const maxScrollLeft = carousel.scrollWidth - carousel.clientWidth;
    const cards = Array.from(carousel.querySelectorAll('.snap-start'));
    return cards.filter(c => (c.offsetLeft - lpad) <= maxScrollLeft + 5);
  }

  function initDots() {
    const validCards = getValidCards();
    const numDots = validCards.length;
    dotsContainer.innerHTML = '';
    
    const maxScrollLeft = carousel.scrollWidth - carousel.clientWidth;
    if (maxScrollLeft <= 0) {
      dotsContainer.style.display = 'none';
      prev.style.display = 'none';
      next.style.display = 'none';
      return;
    } else {
      dotsContainer.style.display = 'flex';
      prev.style.display = 'flex';
      next.style.display = 'flex';
    }

    for (let i = 0; i < numDots; i++) {
      const span = document.createElement('span');
      span.className = 'sdot h-2 rounded-full transition-all duration-300';
      span.style.width = i === current ? '24px' : '8px';
      span.style.background = i === current ? '#50C1FC' : 'rgba(255,255,255,0.2)';
      span.style.cursor = 'pointer';
      span.addEventListener('click', function () { goTo(i); });
      dotsContainer.appendChild(span);
    }
  }

  function setDot(i) {
    const dots = dotsContainer.querySelectorAll('.sdot');
    dots.forEach(function (d, idx) {
      d.style.width           = idx === i ? '24px' : '8px';
      d.style.background      = idx === i ? '#50C1FC' : 'rgba(255,255,255,0.2)';
    });
  }

  function goTo(i) {
    const validCards = getValidCards();
    const numDots = validCards.length;
    if (numDots === 0) return;
    current = (i + numDots) % numDots;
    const lpad = parseInt(window.getComputedStyle(carousel).paddingLeft) || 0;
    if (validCards[current]) {
      carousel.scrollTo({ left: validCards[current].offsetLeft - lpad, behavior: 'smooth' });
    }
    setDot(current);
  }

  // Scroll → actualizar dot
  let st = null;
  carousel.addEventListener('scroll', function () {
    clearTimeout(st);
    st = setTimeout(function () {
      const lpad  = parseInt(window.getComputedStyle(carousel).paddingLeft) || 0;
      const validCards = getValidCards();
      let closest = 0, minDist = Infinity;
      validCards.forEach(function (c, i) {
        const d = Math.abs(c.offsetLeft - lpad - carousel.scrollLeft);
        if (d < minDist) { minDist = d; closest = i; }
      });
      if (closest !== current) { current = closest; setDot(current); }
    }, 50);
  }, { passive: true });

  prev.addEventListener('click', function () { goTo(current - 1); });
  next.addEventListener('click', function () { goTo(current + 1); });

  // Init on load
  initDots();

  // Re-init on resize/load for layout shift adjustments
  window.addEventListener('resize', initDots);
  window.addEventListener('load', initDots);
})();
</script>